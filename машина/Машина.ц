  дія увімкнути_стан_падіння(
    М: *Машина,
    значення_падіння: Значення,
    місцезнаходження_падіння: Місцезнаходження
  ) -> ніщо {
    М.стан_падіння = так;
    М.значення_падіння = значення_падіння;
    М.місцезнаходження_падіння = місцезнаходження_падіння;
  }

  дія вимкнути_стан_падіння(
    М: *Машина
  ) -> ніщо {
    М.стан_падіння = ні;
    М.значення_падіння = НЕДІЙСНЕ;
    М.місцезнаходження_падіння = Місцезнаходження { пусто, 0 };
  }

  дія покласти_в_історію_здійснення(
    М: *Машина,
    дійсність: *Дійсність,
    здійснювач: Значення,
    предмет_дії: *ПредметДії,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> *Діяльність {
    М.історія_здійснення.дані[М.історія_здійснення.розмір] = Діяльність {
      дійсність = дійсність,
      здійснювач = здійснювач,
      предмет_дії = предмет_дії,
      задіяні = задіяні,
      місцезнаходження = місцезнаходження,
      спроби = Спроби { 0, пусто },
    };
    М.історія_здійснення.розмір += 1;

    якщо дійсність != пусто {
      дійсність.кількість_запозичень += 1;
    }

    вернути М.історія_здійснення.дані[М.історія_здійснення.розмір - 1]::адреса;
  }

  дія видалити_з_історії_здійснення(
    М: *Машина,
    кількість: природне
  ) {
    змінна п: природне = 0;

    поки п < кількість {
      змінна діяльність = М.історія_здійснення.дані[М.історія_здійснення.розмір - 1 - п];

      якщо діяльність.дійсність != пусто {
        відпустити_дійсність(М, діяльність.дійсність);
      }

      звільнити(М, діяльність.спроби.дані);

      звільнити_задіяні(М, діяльність.задіяні);

      п += 1;
    }

    М.історія_здійснення.розмір -= кількість;
  }

  дія покласти_в_чергу_здійснення(
    М: *Машина,
    предмет_дії: *ПредметДії,
    задіяні: Задіяні
  ) {
    // ...
  }

  дія забрати_з_черги_здійснення(
    М: *Машина,
    вихід: *ЕлементЧергиЗдійснення
  ) -> логічне {
    якщо М.черга_здійснення.перший != пусто {
      змінна елемент = М.черга_здійснення.перший;

      М.черга_здійснення.перший = елемент.наступний;

      вихід::вміст = елемент::вміст;

      звільнити(М, елемент);

      вернути так;
    } інакше {
      М.черга_здійснення.останній = пусто;

      вернути ні;
    }
  }
}

простір мавка {
  внутрішня дія покласти_в_накопичувач_значень(
    М: *Машина,
    накопичувач_значень: *НакопичувачЗначень,
    значення: Значення
  ) {
    якщо накопичувач_значень.розмір == накопичувач_значень.вмісткість {
      ЗАПАНІКУВАТИ(М, "Накопичувач значень заповнено!");
      вернути;
    }

    накопичувач_значень.дані[накопичувач_значень.розмір] = значення;
    накопичувач_значень.розмір += 1;
  }

  внутрішня дія забрати_з_накопичувача_значень(
    М: *Машина,
    накопичувач_значень: *НакопичувачЗначень
  ) -> Значення {
    якщо накопичувач_значень.розмір == 0 {
      ЗАПАНІКУВАТИ(М, "Накопичувач значень порожній 1!");
    }

    накопичувач_значень.розмір -= 1;

    вернути накопичувач_значень.дані[накопичувач_значень.розмір];
  }

  внутрішня дія отримати_з_накопичувача_значень(
    М: *Машина,
    накопичувач_значень: *НакопичувачЗначень,
    позиція: природне
  ) -> Значення {
    якщо накопичувач_значень.розмір == 0 {
      ЗАПАНІКУВАТИ(М, "Накопичувач значень порожній 2!");
    }

    вернути накопичувач_значень.дані[накопичувач_значень.розмір - 1 - позиція];
  }

  внутрішня дія видалити_з_накопичувача_значень(
    М: *Машина,
    накопичувач_значень: *НакопичувачЗначень,
    кількість: природне
  ) {
    якщо накопичувач_значень.розмір == 0 {
      ЗАПАНІКУВАТИ(М, "Накопичувач значень порожній 3!");
    }

    накопичувач_значень.розмір -= кількість;
  }

  внутрішня дія обробити_стан_падіння(
    М: *Машина,
    спроби: *Спроби,
    дійсність: *Дійсність,
    предмет_коду: *ПредметКоду,
    позиція_вказівки_падіння: природне,
    позиція: *природне
  ) -> логічне {
    якщо спроби.розмір > 0 {
      спроби.розмір -= 1;
      змінна спроба = спроби.дані[спроби.розмір];

      якщо спроба.назва_зловити != пусто {
        записати_в_дійсність(М, дійсність, спроба.назва_зловити, М.значення_падіння);
      }

      позиція::вміст = спроба.позиція_вказівки_зловити;
      М.історія_здійснення.розмір = спроба.розмір_історії_здійснення;
      М.накопичувач_значень.розмір = спроба.розмір_накопичувача_значень;

      М.стан_падіння = ні;
      М.значення_падіння = НЕДІЙСНЕ;
      М.місцезнаходження_падіння = Місцезнаходження { пусто, 0 };

      вернути так;
    }

    якщо (М.місцезнаходження_падіння.шлях_або_код як *ПредметДаних) == пусто {
      М.місцезнаходження_падіння = Місцезнаходження { предмет_коду, позиція_вказівки_падіння };
    }

    вернути ні;
  }

  внутрішня дія прочитати_аргумент_вказівки(вказівки: *ПредметДаних, позиція: *природне) -> п32 {
    позиція::вміст += 1;
    змінна адреса_аргумента = вказівки.дані[позиція::вміст]::адреса як *п32;
    позиція::вміст += 3;
    вернути адреса_аргумента::вміст;
  }

  внутрішня дія виконати_код(
    М: *Машина,
    накопичувач_значень: *НакопичувачЗначень,
    спроби: *Спроби,
    дійсність: *Дійсність,
    здійснювач: Значення,
    предмет_коду: *ПредметКоду,
    початкова_позиція_вказівки: природне,
    шлях_до_теки_модулів: *ПредметДаних
  ) -> ЗначенняАбоСтанПадіння {
    // надрукувати_кд(М, "виконати_код");

    змінна константи = предмет_коду.константи;
    змінна вказівки = предмет_коду.вказівки;

    змінна результат_вернути = НЕДІЙСНЕ;
    змінна результат = НЕДІЙСНЕ;

    змінна позиція = початкова_позиція_вказівки;
    змінна позиція_поточної_вказівки: природне;
    змінна вказівка: п8;

    змінна а1: природне;
    змінна а2: природне;
    змінна а3: природне;

    змінна з1: Значення;
    змінна з2: Значення;
    змінна з3: Значення;
    змінна з4: Значення;

    змінна назва: *ПредметТексту;
    змінна модл1: *ПредметМодуля;
    змінна спис1: *ПредметСписку;
    змінна слов1: *ПредметСловника;
    змінна посл1: *ПредметПослідовності;
    змінна дія1: *ПредметДії;
    змінна клас1: *ПредметКласу;
    змінна ткст1: *ПредметТексту;
    змінна ткст2: *ПредметТексту;

    змінна пред1: *Предмет;
    змінна пред2: *Предмет;

    змінна накопичувач_тексту: НакопичувачТексту;
    змінна дані_назв: **ПредметТексту;
    змінна дані: *п8;

    змінна п: природне = 0; // спільний лічильник
    змінна п1: природне = 0; // спільний лічильник 1

    // надрукувати_кд(М, "Початок виконання коду");
    // надрукувати_п64(М, п64(вказівки.розмір));

    поки позиція < вказівки.розмір {
  крок_виконання_вказівки:
      якщо М.потребує_очищення {
        запустити_очищувач(М);
      }

      позиція_поточної_вказівки = позиція;
      вказівка = вказівки.дані[позиція_поточної_вказівки];

      // вивести_кд(М, "Виконується вказівка: ");
      // надрукувати_п64(М, п64(вказівка));

      якщо вказівка == ВПокластиНедійсне {
        покласти_в_накопичувач_значень(М, накопичувач_значень, НЕДІЙСНЕ);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВПокластиДійсне {
        покласти_в_накопичувач_значень(М, накопичувач_значень, ДІЙСНЕ);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВПокластиПредмет {
        покласти_в_накопичувач_значень(М, накопичувач_значень, ДІЙСНЕ);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВПокластиЯ {
        покласти_в_накопичувач_значень(М, накопичувач_значень, здійснювач);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВПокластиКонстанту {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // позиція_константи

        покласти_в_накопичувач_значень(М, накопичувач_значень, константи.елементи[а1]);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиДію {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_параметрів

        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // код
        з2 = забрати_з_накопичувача_значень(М, накопичувач_значень); // тип_результату

        посл1 = М.пуста_послідовність; // параметри

        якщо а1 > 0 {
          посл1 = створити_сиру_послідовність(М, а1);

          п = 0;

          поки п < а1 {
            посл1.елементи[а1 - п - 1] = забрати_з_накопичувача_значень(М, накопичувач_значень);

            п += 1;
          }
        }

        з3 = забрати_з_накопичувача_значень(М, накопичувач_значень); // назва

        покласти_в_накопичувач_значень(
          М,
          накопичувач_значень,
          ПРЕДМЕТ(створити_дію(
            М,
            дійсність,
            з3.дані як *Предмет як *ПредметТексту,
            посл1,
            пусто,
            з1.дані як *Предмет як *ПредметКоду,
            шлях_до_теки_модулів
          ))
        );

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиКлас {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_параметрів

        посл1 = М.пуста_послідовність;

        якщо а1 > 0 {
          посл1 = створити_сиру_послідовність(М, а1);

          п = 0;

          поки п < а1 {
            посл1.елементи[а1 - п - 1] = забрати_з_накопичувача_значень(М, накопичувач_значень);

            п += 1;
          }
        }

        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // назва

        покласти_в_накопичувач_значень(
          М,
          накопичувач_значень,
          ПРЕДМЕТ(створити_клас(
            М,
            з1.дані як *Предмет як *ПредметТексту,
            посл1
          ))
        );

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиМодуль {
        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // код
        з2 = забрати_з_накопичувача_значень(М, накопичувач_значень); // назва

        модл1 = створити_модуль(
          М,
          з2.дані як *Предмет як *ПредметТексту
        );

        здійснити(
          М,
          ПРЕДМЕТ(модл1),
          ПРЕДМЕТ(створити_дію(
            М,
            дійсність,
            з2.дані як *Предмет як *ПредметТексту,
            М.пуста_послідовність,
            пусто,
            з1.дані як *Предмет як *ПредметКоду,
            шлях_до_теки_модулів
          )),
          Задіяні { ВидЗадіяних2, 0, пусто, 0 },
          Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
        );

        якщо М.стан_падіння {
          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, ПРЕДМЕТ(модл1));

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиСписок {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_елементів

        спис1 = створити_список(М, а1);

        п = 0;

        поки п < а1 {
          записати_в_список(
            М,
            спис1,
            а1 - п - 1,
            забрати_з_накопичувача_значень(М, накопичувач_значень)
          );

          п += 1;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, ПРЕДМЕТ(спис1));

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиСловник {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_елементів

        слов1 = створити_словник(М);

        п = 0;

        поки п < а1 {
          записати_в_словник(
            М,
            слов1,
            отримати_з_накопичувача_значень(М, накопичувач_значень, (а1 * 2) - (п * 2) - 1), // ключ
            отримати_з_накопичувача_значень(М, накопичувач_значень, (а1 * 2) - (п * 2) - 2) // значення
          );

          п += 1;
        }

        видалити_з_накопичувача_значень(М, накопичувач_значень, а1 * 2);

        покласти_в_накопичувач_значень(М, накопичувач_значень, ПРЕДМЕТ(слов1));

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиПослідовність {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_елементів

        посл1 = створити_сиру_послідовність(М, а1);

        п = 0;

        поки п < а1 {
          посл1.елементи[а1 - п - 1] = забрати_з_накопичувача_значень(М, накопичувач_значень);

          п += 1;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, ПРЕДМЕТ(посл1));

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтворитиПроміжок {
        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // до
        з2 = забрати_з_накопичувача_значень(М, накопичувач_значень); // включно
        з3 = забрати_з_накопичувача_значень(М, накопичувач_значень); // від

        з4 = отримати_проміжок(
          М,
          з3,
          з1,
          з2.вид == ЗДійсне,
          Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
        );

        якщо М.стан_падіння {
          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, з4);

        стрибнути крок_виконати_далі;
