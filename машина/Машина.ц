          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, результат);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВДати {
        назва = забрати_з_накопичувача_значень(М, накопичувач_значень).дані як *Предмет як *ПредметТексту;
        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // значення

        якщо здійснювач.вид != ЗПредмет {
          увімкнути_стан_падіння(
            М,
            ПРЕДМЕТ(створити_текст(М, "Неможливо дати.")),
            Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
          );

          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        модл1 = здійснювач.дані як *Предмет як *ПредметМодуля;

        якщо модл1.клас != М.клас_Модуль {
          увімкнути_стан_падіння(
            М,
            ПРЕДМЕТ(створити_текст(М, "Неможливо дати.")),
            Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
          );

          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        записати_властивість_модуля(
          М,
          модл1,
          назва,
          з1
        );

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВПеребратиДалі {
        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // значення

        покласти_в_накопичувач_значень(М, накопичувач_значень, з1);

        результат = здійснити_властивість(
          М,
          з1,
          М.константи_назв._далі,
          Задіяні { ВидЗадіяних2, 0, пусто, 0 },
          Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
        );

        якщо М.стан_падіння {
          якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
            стрибнути крок_виконання_вказівки;
          }

          стрибнути крок_вихід;
        }

        покласти_в_накопичувач_значень(М, накопичувач_значень, результат);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВЗбитиТекст {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // кількість_предметів

        накопичувач_тексту = зробити_накопичувач_тексту(М, а1);

        п = 0;

        поки п < а1 {
          з1 = отримати_з_накопичувача_значень(М, накопичувач_значень, а1 - п - 1); // значення

          ткст1 = отримати_текст(
            М,
            з1,
            Місцезнаходження { предмет_коду, позиція_поточної_вказівки }
          );

          якщо М.стан_падіння {
            звільнити(М, накопичувач_тексту.дані);

            якщо обробити_стан_падіння(М, спроби, дійсність, предмет_коду, позиція_поточної_вказівки, позиція::адреса) {
              стрибнути крок_виконання_вказівки;
            }

            стрибнути крок_вихід;
          }

          покласти_в_накопичувач_тексту(М, накопичувач_тексту::адреса, ткст1.значення);

          п += 1;
        }

        видалити_з_накопичувача_значень(М, накопичувач_значень, а1);

        покласти_в_накопичувач_значень(
          М,
          накопичувач_значень,
          ПРЕДМЕТ(створити_текст_без_копіювання(М, накопичувач_тексту.розмір, накопичувач_тексту.дані))
        );

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтрибнути {
        позиція = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // позиція_вказівки_стрибка;

        стрибнути крок_виконання_вказівки;
      }

      якщо вказівка == ВСтрибнутиЯкщоДійсне {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // позиція_вказівки_стрибка

        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // значення

        якщо з1.вид != ЗНедійсне {
          позиція = а1;

          стрибнути крок_виконання_вказівки;
        }

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВСтрибнутиЯкщоНедійсне {
        а1 = природне(прочитати_аргумент_вказівки(вказівки, позиція::адреса)); // позиція_вказівки_стрибка

        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // значення

        якщо з1.вид == ЗНедійсне {
          позиція = а1;

          стрибнути крок_виконання_вказівки;
        }

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВЗабрати {
        видалити_з_накопичувача_значень(М, накопичувач_значень, 1);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВДублювати {
        з1 = забрати_з_накопичувача_значень(М, накопичувач_значень); // значення

        покласти_в_накопичувач_значень(М, накопичувач_значень, з1);
        покласти_в_накопичувач_значень(М, накопичувач_значень, з1);

        стрибнути крок_виконати_далі;
      }

      якщо вказівка == ВВернути {
        результат_вернути = забрати_з_накопичувача_значень(М, накопичувач_значень);

        стрибнути крок_вихід;
      }

      надрукувати_п64(М, п64(вказівка));
      ЗАПАНІКУВАТИ(М, "Невідома вказівка під час виконання коду.");

  крок_виконати_далі:
      позиція += 1;
    }

  крок_вихід:
    вернути результат_вернути;
  }
}

простір мавка {
  дія предмет_дії_здійснити(
    М: *Машина,
    здійснювач: Значення,
    предмет_дії: *ПредметДії,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо предмет_дії.рідна {
      змінна рідна_дія = предмет_дії.код як РіднаДія;

      змінна діяльність = покласти_в_історію_здійснення(
        М,
        пусто,
        здійснювач,
        предмет_дії,
        задіяні,
        місцезнаходження
      );

      змінна результат = рідна_дія(
        М,
        діяльність
      );

      якщо не М.стан_падіння {
        видалити_з_історії_здійснення(М, 1);
      }

      вернути результат;
    } інакше {
      змінна дійсність = створити_дійсність(
        М,
        предмет_дії.дійсність_створення
      );

      змінна діяльність = покласти_в_історію_здійснення(
        М,
        дійсність,
        здійснювач,
        предмет_дії,
        задіяні,
        місцезнаходження
      );

      змінна розмір_позиційних = задіяні.розмір - (задіяні.кількість_імен * 2);

      якщо предмет_дії.параметри.розмір > 0 {
        змінна п: п32 = 0;

        поки п < п32(предмет_дії.параметри.розмір) {
          змінна параметр = предмет_дії.параметри.елементи[п].дані як *Предмет як *ПредметПараметра;

          якщо п < розмір_позиційних {
            записати_в_дійсність(
              М,
              дійсність,
              параметр.назва,
              задіяні.дані[п]
            );
          } інакше {
            записати_в_дійсність(
              М,
              дійсність,
              параметр.назва,
              параметр.значення
            );
          }

          п += 1;
        }

        якщо задіяні.кількість_імен > 0 {
          п = 0;

          поки п < задіяні.кількість_імен {
            змінна назва = задіяні.дані[розмір_позиційних + задіяні.кількість_імен + п].дані як *Предмет як *ПредметТексту;
            змінна значення = задіяні.дані[розмір_позиційних + п];

            записати_в_дійсність(
              М,
              дійсність,
              назва,
              значення
            );

            п += 1;
          }
        }
      }

      змінна результат = виконати_код(
        М,
        М.накопичувач_значень::адреса,
        діяльність.спроби::адреса,
        дійсність,
        здійснювач,
        предмет_дії.код як *ПредметКоду,
        0,
        предмет_дії.шлях_до_теки_модулів
      );

      якщо М.стан_падіння {
        вернути НЕДІЙСНЕ;
      }

      видалити_з_історії_здійснення(М, 1);

      вернути результат;
    }
  }
}

простір мавка {
  дія обробник_прочитання(сирий_текст: кд, кінець_файлу: логічне, помилка: природне, позиція_помилки: природне, аргумент: адреса) {
    змінна розмова = аргумент як *Розмова;
    змінна М = розмова.М;

    якщо помилка {
      змінна помилка = "Не вдалось перекодувати текст входу розмови.";
      надрукувати_кд(М, помилка);
      стрибнути ще_раз;
    }

    якщо кінець_файлу {
      відпустити_дійсність(М, розмова.дійсність);
      звільнити(М, розмова);
      М.розмова = пусто;
      вернути;
    }

    якщо сирий_текст.розмір == 0 {
      стрибнути ще_раз;
    }

    змінна успіх = ні;
    змінна знаки: розбирач::Знаки;
    змінна помилка_розбору_на_знаки: розбирач::ПомилкаРозборуНаЗнаки;
    змінна сполуки: розбирач::Сполуки;
    змінна помилка_розбору_на_сполуки: розбирач::ПомилкаРозборуНаСполуки;
    змінна перекладений_код: *ПредметКоду = пусто;
    змінна помилка_перекладу: перекладач::ПомилкаПерекладу;
    змінна інформація_падіння: ІнформаціяПадіння;

    успіх = розбирач::розібрати_на_знаки(
      М,
      сирий_текст,
      знаки::адреса,
      помилка_розбору_на_знаки::адреса
    );
    якщо не успіх {
      змінна рядок = розбирач::отримати_рядок_помилки_розбору_на_знаки(
        М,
        помилка_розбору_на_знаки
      );
      змінна помилка = "Не вдалось розібрати текст входу розмови.";
      надрукувати_кд(М, помилка);
      стрибнути ще_раз;
    }

    успіх = розбирач::розібрати_знаки_на_сполуки(
      М,
      сирий_текст,
      знаки,
      сполуки::адреса,
      помилка_розбору_на_сполуки::адреса
    );
    якщо не успіх {
      змінна рядок = розбирач::отримати_рядок_помилки_розбору_на_сполуки(
        М,
        помилка_розбору_на_сполуки
      );
      змінна помилка = "Не вдалось розібрати знаки входу розмови.";
      надрукувати_кд(М, помилка);
      стрибнути ще_раз;
    }

    успіх = перекласти_в_код(
      М,
      розмова.шлях_до_стандартного_вводу,
      сирий_текст,
      знаки,
      сполуки,
      перекладений_код::адреса,
      помилка_перекладу::адреса
    );
    якщо не успіх {
      змінна помилка = "Не вдалось перекласти сполуки на код.";
      надрукувати_кд(М, помилка);
      стрибнути ще_раз;
    }

    змінна предмет_дії = створити_дію(
      М,
      розмова.дійсність,
      створити_текст(М, "розмова"),
      М.пуста_послідовність,
      пусто,
      перекладений_код,
      М.шлях_до_теки_модулів
    );

    змінна розмір_історії = М.історія_здійснення.розмір;
    змінна розмір_накопичувача_значень = М.накопичувач_значень.розмір;

    змінна елемент_історії = покласти_в_історію_здійснення(
      М,
      розмова.дійсність,
      ПРЕДМЕТ(розмова.предмет_модуля),
      предмет_дії,
      Задіяні { ВидЗадіяних2, 0, пусто, 0 },
      Місцезнаходження { розмова.шлях_до_стандартного_вводу, 0 }
    );

    змінна результат = виконати_код(
      М,
      М.накопичувач_значень::адреса,
      елемент_історії.спроби::адреса,
      розмова.дійсність,
      ПРЕДМЕТ(розмова.предмет_модуля),
      перекладений_код,
      0,
      предмет_дії.шлях_до_теки_модулів
    );

    якщо отримати_інформацію_падіння(М, інформація_падіння::адреса) {
      розмова.обробити_падіння(
        М,
        інформація_падіння
      );

      знищити_інформацію_падіння(М, інформація_падіння);

      вимкнути_стан_падіння(М);
    } інакше {
      розмова.обробити_значення(М, результат);
    }

    видалити_з_історії_здійснення(М, М.історія_здійснення.розмір - розмір_історії);
    М.накопичувач_значень.розмір = розмір_накопичувача_значень;

  ще_раз:
    розмова.читати(
      М,
      "- ",
      так,
      обробник_прочитання,
      розмова
    );
  }

  дія почати_розмову(
    М: *Машина,
    шлях_до_стандартного_вводу: *ПредметДаних,
    читати: ПочатиРозмовуДіяЧитати,
    обробити_значення: ПочатиРозмовуДіяОбробитиЗначення,
    обробити_падіння: ПочатиРозмовуДіяОбробитиПадіння,
  ) {
    якщо М.розмова != пусто {
      вернути; // потім: помилка?
    }

    змінна предмет_модуля = створити_модуль(
      М,
      створити_текст(М, "розмова")
    );

    змінна дійсність = створити_дійсність(
      М,
      М.глобальна_дійсність
    );
    дійсність.кількість_запозичень += 1;

    М.розмова = виділити<Розмова>(М, 1);
    М.розмова.М = М;
    М.розмова.читати = читати;
    М.розмова.шлях_до_стандартного_вводу = шлях_до_стандартного_вводу;
    М.розмова.обробити_значення = обробити_значення;
    М.розмова.обробити_падіння = обробити_падіння;
    М.розмова.предмет_модуля = предмет_модуля;
    М.розмова.дійсність = дійсність;

    читати(
      М,
      "- ",
      так,
      обробник_прочитання,
      М.розмова
    );
  }
}