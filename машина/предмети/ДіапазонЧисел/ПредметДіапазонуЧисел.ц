взяти означення мавка/машина;

простір мавка {
  дія записати_метод_структури_ДіапазонЧисел__чародія_перебір(М: адреса<Машина>);

  дія заповнити_структуру_ДіапазонЧисел(
    М: адреса<Машина>
  ) {
    М.предмет_структури_ДіапазонЧисел.вбудована = так;
    М.предмет_структури_ДіапазонЧисел.заборонити_наслідування = так;

    записати_метод_структури_ДіапазонЧисел__чародія_перебір(М);
  }

  дія створити_діапазон_чисел(
    М: адреса<Машина>,
    від: р64,
    до: р64,
    включно: логічне
  ) -> адреса<ПредметДіапазонуЧисел> {
    змінна предмет = виділити_предмет<ПредметДіапазонуЧисел>(М, М.предмет_структури_ДіапазонЧисел);

    предмет.від = від;
    предмет.до = до;
    предмет.включно = включно;

    вернути предмет;
  }

  дія здійснити_структуру_діапазону_чисел(
    М: адреса<Машина>,
    предмет_структури: адреса<ПредметСтруктури>,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити структуру \"ДіапазонЧисел\"."), місцезнаходження);
  }

  дія предмет_діапазону_чисел_отримати_властивість(
    М: адреса<Машина>,
    предмет_діапазону_чисел: адреса<ПредметДіапазонуЧисел>,
    назва: адреса<ПредметТексту>,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    змінна предмет_методу = знайти_метод_в_структурі(
      М,
      М.предмет_структури_ДіапазонЧисел,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}