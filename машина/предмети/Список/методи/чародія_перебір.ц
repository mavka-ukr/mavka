взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Список__чародія_перебір(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію списку \"чародія перебір\"."));
    }

    змінна предмет_списку = діяльність.здійснювач.дані як *Предмет як *ПредметСписку;

    якщо предмет_списку.клас != М.клас_Список {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію списку \"чародія перебір\"."));
    }

    вернути ПРЕДМЕТ(створити_перебір_списку(
      М,
      предмет_списку
    ));
  }

  дія записати_метод_класу_Список__чародія_перебір(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_перебір,
      М.пуста_послідовність,
      пусто,
      рідна_дія_методу_структури_Список__чародія_перебір,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Список,
      М.константи_назв._чародія_перебір,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"чародія_перебір\" для структури \"Список\".");
    }
  }
}