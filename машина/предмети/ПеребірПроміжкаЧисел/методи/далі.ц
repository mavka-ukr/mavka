    }

    змінна предмет_перебору_проміжка_чисел = діяльність.здійснювач.дані як *Предмет як *ПредметПереборуПроміжкаЧисел;

    якщо предмет_перебору_проміжка_чисел.клас != М.клас_ПеребірПроміжкаЧисел {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію перебору проміжка чисел \"далі\"."));
    }

    якщо предмет_перебору_проміжка_чисел.почато {
      предмет_перебору_проміжка_чисел.поточне_значення = предмет_перебору_проміжка_чисел.поточне_значення + 1.0;
    } інакше {
      предмет_перебору_проміжка_чисел.поточне_значення = предмет_перебору_проміжка_чисел.предмет_проміжка.від;
      предмет_перебору_проміжка_чисел.почато = так;
    }

    якщо предмет_перебору_проміжка_чисел.предмет_проміжка.включно {
      якщо предмет_перебору_проміжка_чисел.поточне_значення <= предмет_перебору_проміжка_чисел.предмет_проміжка.до {
        вернути ДІЙСНЕ;
      }
    } інакше {
      якщо предмет_перебору_проміжка_чисел.поточне_значення < предмет_перебору_проміжка_чисел.предмет_проміжка.до {
        вернути ДІЙСНЕ;
      }
    }

    вернути НЕДІЙСНЕ;
  }

  дія записати_метод_класу_ПеребірПроміжкаЧисел__далі(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._далі,
      М.пуста_послідовність,
      пусто,
      рідна_дія_метода_структури_ПеребірПроміжкаЧисел__далі,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_ПеребірПроміжкаЧисел,
      М.константи_назв._далі,
      предмет_дії
    );
