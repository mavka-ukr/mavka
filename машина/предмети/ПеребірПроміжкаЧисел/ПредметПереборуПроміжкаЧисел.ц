взяти визначення мавка/машина;

простір мавка {
  дія записати_метод_класу_ПеребірПроміжкаЧисел__далі(М: *Машина);

  внутрішня дія записати_параметри_структури_ПеребірПроміжкаЧисел(М: *Машина) {
    змінна кількість_параметрів = природне(2);
    змінна дані_параметрів = виділити<Значення>(М, кількість_параметрів);

    дані_параметрів[0] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._значення,
      пусто,
      пусто
    ));
    дані_параметрів[1] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._проміжок,
      пусто,
      пусто
    ));

    М.клас_ПеребірПроміжкаЧисел.параметри = створити_послідовність_без_копіювання(
      М,
      кількість_параметрів,
      дані_параметрів
    );
  }

  дія заповнити_клас_ПеребірПроміжкаЧисел(
    М: *Машина
  ) {
    М.клас_ПеребірПроміжкаЧисел.вбудований = так;
    М.клас_ПеребірПроміжкаЧисел.заборонити_наслідування = так;

    записати_параметри_структури_ПеребірПроміжкаЧисел(М);

    записати_метод_класу_ПеребірПроміжкаЧисел__далі(М);
  }

  дія створити_перебір_проміжка_чисел(
    М: *Машина,
    предмет_проміжка: *ПредметПроміжкаЧисел
  ) -> *ПредметПереборуПроміжкаЧисел {
    змінна предмет = виділити_предмет<ПредметПереборуПроміжкаЧисел>(М, М.клас_ПеребірПроміжкаЧисел);

    предмет.предмет_проміжка = предмет_проміжка;
    предмет.почато = ні;
    предмет.поточне_значення = 0.0;

    вернути предмет;
  }

  дія здійснити_клас_перебору_проміжка_чисел(
    М: *Машина,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити клас \"ПеребірПроміжкаЧисел\"."), місцезнаходження);
  }

  дія предмет_перебору_проміжка_чисел_отримати_властивість(
    М: *Машина,
    предмет_перебору_проміжка_чисел: *ПредметПереборуПроміжкаЧисел,
    назва: *ПредметТексту,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._значення) {
      якщо предмет_перебору_проміжка_чисел.почато {
        вернути ЧИСЛО(предмет_перебору_проміжка_чисел.поточне_значення);
      }
      вернути НЕДІЙСНЕ;
    }
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._проміжок) {
      вернути ПРЕДМЕТ(предмет_перебору_проміжка_чисел.предмет_проміжка);
    }

    змінна предмет_методу = знайти_метод_в_класі(
      М,
      М.клас_ПеребірПроміжкаЧисел,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}