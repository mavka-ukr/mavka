взяти визначення мавка;

простір мавка {
  внутрішня дія рідна_дія_структури_Модуль__отримати_назву(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    змінна задіяне_значення = НЕДІЙСНЕ;

    знайти_задіяне(М, діяльність.задіяні, 0, М.константи_назв._значення, задіяне_значення::адреса);

    якщо задіяне_значення.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Задіяне \"значення\" має бути модулем."));
    }

    змінна предмет_модуля = задіяне_значення.дані як *Предмет як *ПредметМодуля;

    якщо предмет_модуля.клас != М.клас_Модуль {
      вернути ПАДІННЯ(М, створити_текст(М, "Задіяне \"значення\" має бути модулем."));
    }

    якщо предмет_модуля.назва == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_модуля.назва);
  }

  дія записати_дію_класу_Модуль__отримати_назву(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._отримати_назву,
      М.пуста_послідовність,
      пусто,
      рідна_дія_структури_Модуль__отримати_назву,
      пусто
    );

    клас_змінити_властивість(
      М,
      М.клас_Модуль,
      М.константи_назв._отримати_назву,
      ПРЕДМЕТ(предмет_дії),
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"отримати_назву\" для структури \"Модуль\".");
    }
  }
}