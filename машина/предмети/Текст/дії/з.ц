взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія__з(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    змінна задіяне_значення = НЕДІЙСНЕ;

    знайти_задіяне(М, діяльність.задіяні, 0, М.константи_назв._значення, задіяне_значення::адреса);

    змінна предмет_тексту = отримати_текст(
      М,
      задіяне_значення,
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_тексту);
  }

  дія записати_дію_структури_Текст__з(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._з,
      М.предмет_пустої_послідовності,
      пусто,
      рідна_дія__з,
      пусто
    );

    змінити_властивість_класу(
      М,
      М.клас_Текст,
      М.константи_назв._з,
      ПРЕДМЕТ(предмет_дії)
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"з\" для структури \"Текст\".");
    }
  }
}