взяти означення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Текст__чародія_перебір(
    М: адреса<Машина>,
    діяльність: адреса<Діяльність>
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію тексту \"чародія_перебір\"."));
    }

    змінна предмет_тексту = діяльність.здійснювач.дані як адреса<Предмет> як адреса<ПредметТексту>;

    якщо предмет_тексту.клас != М.клас_Текст {
      вернути ПАДІННЯ(М, створити_текст(М, "Дію \"чародія_перебір\" можна застосувати лише до тексту."));
    }

    вернути ПРЕДМЕТ(створити_перебір_тексту(
      М,
      предмет_тексту
    ));
  }

  дія записати_метод_класу_Текст__чародія_перебір(
    М: адреса<Машина>
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_перебір,
      М.предмет_пустої_послідовності,
      пусто,
      рідна_дія_методу_структури_Текст__чародія_перебір,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Текст,
      М.константи_назв._чародія_перебір,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"чародія_перебір\" для структури \"Текст\".");
    }
  }
}