взяти означення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Текст__чародія_число(
    М: адреса<Машина>,
    діяльність: адреса<Діяльність>
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію тексту \"чародія_число\"."));
    }

    змінна предмет_тексту = діяльність.здійснювач.дані як адреса<Предмет> як адреса<ПредметТексту>;

    якщо предмет_тексту.тип != М.предмет_структури_Текст {
      вернути ПАДІННЯ(М, створити_текст(М, "Дію \"чародія_число\" можна застосувати лише до тексту."));
    }

    змінна розібране_число = р64(0.0);

    якщо не розібрати_число_з_кд(М, предмет_тексту.значення, розібране_число::адреса) {
      вернути НЕДІЙСНЕ;
    }

    вернути ЧИСЛО(розібране_число);
  }

  дія записати_метод_структури_Текст__чародія_число(
    М: адреса<Машина>
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_число,
      М.предмет_пустої_послідовності,
      пусто,
      рідна_дія_методу_структури_Текст__чародія_число,
      пусто
    );

    записати_метод_структури(
      М,
      М.предмет_структури_Текст,
      М.константи_назв._чародія_число,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"чародія_число\" для структури \"Текст\".");
    }
  }
}