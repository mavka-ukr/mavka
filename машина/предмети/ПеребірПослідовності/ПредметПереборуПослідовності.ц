взяти означення мавка/машина;

простір мавка {
  дія записати_метод_структури_ПеребірПослідовності__далі(М: адреса<Машина>);

  внутрішня дія записати_параметри_структури_ПеребірПослідовності(М: адреса<Машина>) {
    змінна кількість_параметрів = природне(3);
    змінна дані_параметрів = виділити<Значення>(М, кількість_параметрів);

    дані_параметрів[0] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._послідовність,
      пусто,
      пусто
    ));
    дані_параметрів[1] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._значення,
      пусто,
      пусто
    ));
    дані_параметрів[2] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._позиція,
      пусто,
      пусто
    ));

    М.предмет_структури_ПеребірПослідовності.параметри = створити_послідовність_без_копіювання(
      М,
      кількість_параметрів,
      дані_параметрів
    );
  }

  дія заповнити_структуру_ПеребірПослідовності(
    М: адреса<Машина>
  ) {
    М.предмет_структури_ПеребірПослідовності.вбудована = так;
    М.предмет_структури_ПеребірПослідовності.заборонити_наслідування = так;

    записати_параметри_структури_ПеребірПослідовності(М);

    записати_метод_структури_ПеребірПослідовності__далі(М);
  }

  дія створити_перебір_послідовності(
    М: адреса<Машина>,
    предмет_послідовності: адреса<ПредметПослідовності>
  ) -> адреса<ПредметПереборуПослідовності> {
    змінна предмет = виділити_предмет<ПредметПереборуПослідовності>(М, М.предмет_структури_ПеребірПослідовності);

    предмет.предмет_послідовності = предмет_послідовності;
    предмет.почато = ні;
    предмет.позиція = 0;
    предмет.поточне_значення = НЕДІЙСНЕ;

    вернути предмет;
  }

  дія здійснити_структуру_перебору_послідовності(
    М: адреса<Машина>,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити структуру \"ПеребірПослідовності\"."), місцезнаходження);
  }

  дія предмет_перебору_послідовності_отримати_властивість(
    М: адреса<Машина>,
    предмет_перебору_послідовності: адреса<ПредметПереборуПослідовності>,
    назва: адреса<ПредметТексту>,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._значення) {
      вернути предмет_перебору_послідовності.поточне_значення;
    }

    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._послідовність) {
      вернути ПРЕДМЕТ(предмет_перебору_послідовності.предмет_послідовності);
    }

    змінна предмет_методу = знайти_метод_в_структурі(
      М,
      М.предмет_структури_ПеребірПослідовності,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}