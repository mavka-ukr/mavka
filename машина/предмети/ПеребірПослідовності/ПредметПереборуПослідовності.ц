взяти визначення мавка/машина;

простір мавка {
  дія записати_метод_класу_ПеребірПослідовності__далі(М: *Машина);

  внутрішня дія записати_ознаки_класу_ПеребірПослідовності(М: *Машина) {
    змінна кількість_ознак = природне(3);
    змінна дані_ознак = виділити<Значення>(М, кількість_ознак);

    дані_ознак[0] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._значення,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[1] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._послідовність,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[2] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._позиція,
      пусто,
      НЕДІЙСНЕ
    ));

    М.клас_ПеребірПослідовності.ознаки = створити_послідовність_без_копіювання(
      М,
      кількість_ознак,
      дані_ознак
    );
  }

  дія заповнити_клас_ПеребірПослідовності(
    М: *Машина
  ) {
    М.клас_ПеребірПослідовності.вбудований = так;
    М.клас_ПеребірПослідовності.заборонити_наслідування = так;

    записати_ознаки_класу_ПеребірПослідовності(М);

    записати_метод_класу_ПеребірПослідовності__далі(М);
  }

  дія створити_перебір_послідовності(
    М: *Машина,
    предмет_послідовності: *ПредметПослідовності
  ) -> *ПредметПереборуПослідовності {
    змінна предмет = виділити_предмет<ПредметПереборуПослідовності>(М, М.клас_ПеребірПослідовності);

    предмет.предмет_послідовності = предмет_послідовності;
    предмет.почато = ні;
    предмет.позиція = 0;
    предмет.поточне_значення = НЕДІЙСНЕ;

    вернути предмет;
  }

  дія здійснити_клас_перебору_послідовності(
    М: *Машина,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити клас \"ПеребірПослідовності\"."), місцезнаходження);
  }

  дія предмет_перебору_послідовності_отримати_властивість(
    М: *Машина,
    предмет_перебору_послідовності: *ПредметПереборуПослідовності,
    назва: *ПредметТексту,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._значення) {
      якщо предмет_перебору_послідовності.почато {
        вернути предмет_перебору_послідовності.поточне_значення;
      }
      вернути НЕДІЙСНЕ;
    }
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._послідовність) {
      вернути ПРЕДМЕТ(предмет_перебору_послідовності.предмет_послідовності);
    }
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._позиція) {
      якщо предмет_перебору_послідовності.почато {
        вернути ЧИСЛО(р64(предмет_перебору_послідовності.позиція));
      }
      вернути НЕДІЙСНЕ;
    }

    змінна предмет_методу = знайти_метод_в_класі(
      М,
      М.клас_ПеребірПослідовності,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}