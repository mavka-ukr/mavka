взяти означення мавка/машина;

простір мавка {
  дія записати_метод_класу_Словник__чародія_текст(М: адреса<Машина>);
  дія записати_метод_класу_Словник__чародія_перебір(М: адреса<Машина>);
  дія записати_метод_класу_Словник__ключі(М: адреса<Машина>);
  дія записати_метод_класу_Словник__значення(М: адреса<Машина>);
  дія записати_метод_класу_Словник__містить(М: адреса<Машина>);

  внутрішня дія записати_параметри_структури_Словник(М: адреса<Машина>) {
    змінна кількість_параметрів = природне(1);
    змінна дані_параметрів = виділити<Значення>(М, кількість_параметрів);

    дані_параметрів[0] = ПРЕДМЕТ(створити_параметр(
      М,
      М.константи_назв._розмір,
      пусто,
      пусто
    ));

    М.клас_Словник.параметри = створити_послідовність_без_копіювання(
      М,
      кількість_параметрів,
      дані_параметрів
    );
  }

  дія заповнити_клас_Словник(
    М: адреса<Машина>
  ) {
    М.клас_Словник.вбудований = так;
    М.клас_Словник.заборонити_наслідування = так;

    записати_параметри_структури_Словник(М);

    записати_метод_класу_Словник__чародія_текст(М);
    записати_метод_класу_Словник__чародія_перебір(М);
    записати_метод_класу_Словник__ключі(М);
    записати_метод_класу_Словник__значення(М);
    записати_метод_класу_Словник__містить(М);
  }

  дія створити_словник(
    М: адреса<Машина>
  ) -> адреса<ПредметСловника> {
    змінна предмет = виділити_предмет<ПредметСловника>(М, М.клас_Словник);

    предмет.розмір = 0;
    предмет.елементи = пусто;

    вернути предмет;
  }

  дія записати_в_словник(
    М: адреса<Машина>,
    словник: адреса<ПредметСловника>,
    ключ: Значення,
    значення: Значення
  ) {
    змінна властивості_словника = словник;

    змінна п: природне = 0;

    поки п < властивості_словника.розмір {
      змінна елемент = властивості_словника.елементи[п]::адреса;

      якщо перевірити_чи_значення_рівні(М, елемент.ключ, ключ) {
        елемент.значення = значення;

        вернути;
      }

      п += 1;
    }

    властивості_словника.елементи = перевиділити<ЕлементСловника>(М, властивості_словника.елементи, властивості_словника.розмір + 1);
    властивості_словника.елементи[властивості_словника.розмір] = ЕлементСловника { ключ, значення };
    властивості_словника.розмір += 1;
  }

  дія здійснити_структуру_словника(
    М: адреса<Машина>,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити структуру \"Словник\"."), місцезнаходження);
  }

  дія предмет_словника_отримати_властивість(
    М: адреса<Машина>,
    предмет_словника: адреса<ПредметСловника>,
    назва: адреса<ПредметТексту>,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._розмір) {
      вернути ЧИСЛО(р64(предмет_словника.розмір));
    }

    змінна предмет_методу = знайти_метод_в_класі(
      М,
      М.клас_Словник,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }

  дія предмет_словника_отримати_елемент(
    М: адреса<Машина>,
    предмет_словника: адреса<ПредметСловника>,
    ключ: Значення,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    змінна п: природне = 0;

    поки п < предмет_словника.розмір {
      змінна елемент = предмет_словника.елементи[п];

      якщо перевірити_чи_значення_рівні(М, елемент.ключ, ключ) {
        вернути елемент.значення;
      }

      п += 1;
    }

    вернути НЕДІЙСНЕ;
  }

  дія предмет_словника_змінити_елемент(
    М: адреса<Машина>,
    предмет_словника: адреса<ПредметСловника>,
    ключ: Значення,
    значення_елемента: Значення,
    місцезнаходження: Місцезнаходження
  ) -> СтанПадіння {
    змінна п: природне = 0;

    поки п < предмет_словника.розмір {
      змінна елемент = предмет_словника.елементи[п]::адреса;

      якщо перевірити_чи_значення_рівні(М, елемент.ключ, ключ) {
        елемент.значення = значення_елемента;

        вернути;
      }

      п += 1;
    }
  }
}