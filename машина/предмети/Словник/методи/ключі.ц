взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Словник__ключі(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію словника \"ключі\"."));
    }

    змінна предмет_словника = діяльність.здійснювач.дані як *Предмет як *ПредметСловника;

    якщо предмет_словника.клас != М.клас_Словник {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію словника \"ключі\"."));
    }

    змінна п: природне = 0;

    поки п < предмет_словника.розмір {
      п += 1;
    }

    вернути НЕДІЙСНЕ;
  }

  дія записати_метод_класу_Словник__ключі(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._ключі,
      М.пуста_послідовність,
      пусто,
      рідна_дія_методу_структури_Словник__ключі,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Словник,
      М.константи_назв._ключі,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"ключі\" для структури \"Словник\".");
    }
  }
}