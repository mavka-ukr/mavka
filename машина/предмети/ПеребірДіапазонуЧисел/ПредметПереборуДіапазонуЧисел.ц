взяти означення мавка/машина;

простір мавка {
  дія записати_метод_структури_ПеребірДіапазонуЧисел__далі(М: адреса<Машина>);

  дія заповнити_структуру_ПеребірДіапазонуЧисел(
    М: адреса<Машина>
  ) {
    М.предмет_структури_ПеребірДіапазонуЧисел.вбудована = так;
    М.предмет_структури_ПеребірДіапазонуЧисел.заборонити_наслідування = так;

    записати_метод_структури_ПеребірДіапазонуЧисел__далі(М);
  }

  дія створити_перебір_діапазону_чисел(
    М: адреса<Машина>,
    предмет_діапазону: адреса<ПредметДіапазонуЧисел>
  ) -> адреса<ПредметПереборуДіапазонуЧисел> {
    змінна предмет = виділити_предмет<ПредметПереборуДіапазонуЧисел>(М, М.предмет_структури_ПеребірДіапазонуЧисел);

    предмет.предмет_діапазону = предмет_діапазону;
    предмет.почато = ні;
    предмет.поточне_значення = 0.0;

    вернути предмет;
  }

  дія здійснити_структуру_перебору_діапазону_чисел(
    М: адреса<Машина>,
    предмет_структури: адреса<ПредметСтруктури>,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити структуру \"ПеребірДіапазонуЧисел\"."), місцезнаходження);
  }

  дія предмет_перебору_діапазону_чисел_отримати_властивість(
    М: адреса<Машина>,
    предмет_перебору_діапазону_чисел: адреса<ПредметПереборуДіапазонуЧисел>,
    назва: адреса<ПредметТексту>,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._значення) {
      вернути ЧИСЛО(предмет_перебору_діапазону_чисел.поточне_значення);
    }

    якщо перевірити_чи_предмети_тексту_рівні(М, назва, М.константи_назв._діапазон) {
      вернути ПРЕДМЕТ(предмет_перебору_діапазону_чисел.предмет_діапазону);
    }

    змінна предмет_методу = знайти_метод_в_структурі(
      М,
      М.предмет_структури_ПеребірДіапазонуЧисел,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}