взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Дані__чародія_перебір(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію даних \"чародія_перебір\"."));
    }

    змінна предмет_даних = діяльність.здійснювач.дані як *Предмет як *ПредметДаних;

    якщо предмет_даних.клас != М.клас_Дані {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію даних \"чародія_перебір\"."));
    }

    вернути ПРЕДМЕТ(створити_перебір_даних(
      М,
      предмет_даних
    ));
  }

  дія записати_метод_класу_Дані__чародія_перебір(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_перебір,
      М.предмет_пустої_послідовності,
      пусто,
      рідна_дія_методу_структури_Дані__чародія_перебір,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Дані,
      М.константи_назв._чародія_перебір,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"чародія_перебір\" для структури \"Дані\".");
    }
  }
}