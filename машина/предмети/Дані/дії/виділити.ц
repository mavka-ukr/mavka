взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_структури_Дані__виділити(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    змінна задіяні = діяльність.задіяні;

    змінна задіяне_розмір = НЕДІЙСНЕ;
    змінна знайдено_задіяне_розмір = ні;

    знайдено_задіяне_розмір = знайти_задіяне(М, задіяні, 0, М.константи_назв._розмір, задіяне_розмір::адреса);

    якщо не знайдено_задіяне_розмір {
      вернути ПАДІННЯ(М, створити_текст(М, "Задіяне \"розмір\" має бути числом."));
    }

    якщо задіяне_розмір.вид != ЗЧисло {
      вернути ПАДІННЯ(М, створити_текст(М, "Задіяне \"розмір\" має бути числом."));
    }

    змінна розмір = природне(задіяне_розмір.дані як р64);
    змінна дані = виділити<п8>(М, розмір);

    вернути ПРЕДМЕТ(створити_дані_без_копіювання(
      М,
      розмір,
      дані
    ));
  }

  дія записати_дію_класу_Дані__виділити(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._виділити,
      М.пуста_послідовність,
      пусто,
      рідна_дія_структури_Дані__виділити,
      пусто
    );

    клас_змінити_властивість(
      М,
      М.клас_Дані,
      М.константи_назв._виділити,
      ПРЕДМЕТ(предмет_дії),
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"виділити\" для структури \"Дані\".");
    }
  }
}