взяти визначення мавка;

простір мавка {
  дія записати_метод_класу_ПеребірТексту__далі(М: *Машина);

  внутрішня дія записати_ознаки_класу_ПеребірТексту(М: *Машина) {
    змінна кількість_ознак = природне(3);
    змінна дані_ознак = виділити<Значення>(М, кількість_ознак);

    дані_ознак[0] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._значення,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[1] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._текст,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[2] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._позиція,
      пусто,
      НЕДІЙСНЕ
    ));

    М.клас_ПеребірТексту.ознаки = створити_послідовність_без_копіювання(
      М,
      кількість_ознак,
      дані_ознак
    );
  }

  внутрішня дія записати_властивість_класу_Текст__Перебір(М: *Машина) {
    клас_змінити_властивість(
      М,
      М.клас_Текст,
      М.константи_назв._Перебір,
      ПРЕДМЕТ(М.клас_ПеребірТексту),
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі властивості \"Перебір\" для класу \"Текст\".");
    }
  }

  дія заповнити_клас_ПеребірТексту(
    М: *Машина
  ) {
    М.клас_ПеребірТексту.вбудований = так;
    М.клас_ПеребірТексту.заборонити_наслідування = так;

    записати_ознаки_класу_ПеребірТексту(М);

    записати_метод_класу_ПеребірТексту__далі(М);

    записати_властивість_класу_Текст__Перебір(М);
  }

  дія створити_перебір_тексту(
    М: *Машина,
    предмет_тексту: *ПредметТексту
  ) -> *ПредметПереборуТексту {
    змінна предмет = виділити_предмет<ПредметПереборуТексту>(М, М.клас_ПеребірТексту);

    предмет.предмет_тексту = предмет_тексту;
    предмет.почато = ні;
    предмет.позиція = 0;
    предмет.поточне_значення = 0.0;

    вернути предмет;
  }

  дія здійснити_клас_перебору_тексту(
    М: *Машина,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо здійснити клас \"ПеребірТексту\"."), місцезнаходження);
  }

  дія предмет_перебору_тексту_отримати_властивість(
    М: *Машина,
    предмет_перебору_тексту: *ПредметПереборуТексту,
    назва: *ПредметТексту,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо порівняти_тексти(М, назва, М.константи_назв._значення) {
      якщо предмет_перебору_тексту.почато {
        вернути ЧИСЛО(предмет_перебору_тексту.поточне_значення);
      }
      вернути НЕДІЙСНЕ;
    }
    якщо порівняти_тексти(М, назва, М.константи_назв._текст) {
      вернути ПРЕДМЕТ(предмет_перебору_тексту.предмет_тексту);
    }
    якщо порівняти_тексти(М, назва, М.константи_назв._позиція) {
      якщо предмет_перебору_тексту.почато {
        вернути ЧИСЛО(р64(предмет_перебору_тексту.позиція));
      }
      вернути НЕДІЙСНЕ;
    }

    змінна предмет_методу = знайти_метод_в_класі(
      М,
      М.клас_ПеребірТексту,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}