взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_ПроміжокЧисел__чародія_перебір(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію проміжка чисел \"чародія_перебір\"."));
    }

    змінна предмет_проміжка_чисел = діяльність.здійснювач.дані як *Предмет як *ПредметПроміжкаЧисел;

    якщо предмет_проміжка_чисел.клас != М.клас_ПроміжокЧисел {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію проміжка чисел \"чародія_перебір\"."));
    }

    вернути ПРЕДМЕТ(створити_перебір_проміжка_чисел(
      М,
      предмет_проміжка_чисел
    ));
  }

  дія записати_метод_класу_ПроміжокЧисел__чародія_перебір(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_перебір,
      М.пуста_послідовність,
      пусто,
      рідна_дія_методу_структури_ПроміжокЧисел__чародія_перебір,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_ПроміжокЧисел,
      М.константи_назв._чародія_перебір,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі методу \"чародія_перебір\" для класу \"ПроміжокЧисел\".");
    }
  }
}