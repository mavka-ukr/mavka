взяти визначення мавка;

простір мавка {
  дія записати_метод_класу_Дія__чародія_текст(М: *Машина);

  внутрішня дія записати_ознаки_класу_Дія(М: *Машина) {
    змінна кількість_ознак = природне(4);
    змінна дані_ознак = виділити<Значення>(М, кількість_ознак);

    дані_ознак[0] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._назва,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[1] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._параметри,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[2] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._тип_результату,
      пусто,
      НЕДІЙСНЕ
    ));
    дані_ознак[3] = ПРЕДМЕТ(створити_ознаку(
      М,
      М.константи_назв._код,
      пусто,
      НЕДІЙСНЕ
    ));

    М.клас_Дія.ознаки = створити_послідовність_без_копіювання(
      М,
      кількість_ознак,
      дані_ознак
    );
  }

  внутрішня дія записати_властивість_класу_Дія__Параметр(М: *Машина) {
    клас_змінити_властивість(
      М,
      М.клас_Дія,
      М.константи_назв._Параметр,
      ПРЕДМЕТ(М.клас_Параметр),
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі властивості \"Параметр\" для класу \"Дія\".");
    }
  }

  внутрішня дія записати_властивість_класу_Дія__Код(М: *Машина) {
    клас_змінити_властивість(
      М,
      М.клас_Дія,
      М.константи_назв._Код,
      ПРЕДМЕТ(М.клас_Код),
      Місцезнаходження { пусто, 0 }
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі властивості \"Код\" для класу \"Дія\".");
    }
  }

  дія заповнити_клас_Дія(
    М: *Машина
  ) {
    М.клас_Дія.вбудований = так;
    М.клас_Дія.заборонити_наслідування = так;

    записати_ознаки_класу_Дія(М);

    записати_метод_класу_Дія__чародія_текст(М);

    записати_властивість_класу_Дія__Параметр(М);
    записати_властивість_класу_Дія__Код(М);
  }

  дія створити_дію(
    М: *Машина,
    дійсність_створення: *Дійсність,
    назва: *ПредметТексту,
    параметри: *ПредметПослідовності,
    тип_результату: *Предмет,
    код: *ПредметКоду,
    шлях_до_теки_модулів: *ПредметДаних
  ) -> *ПредметДії {
    змінна предмет = виділити_предмет<ПредметДії>(М, М.клас_Дія);

    предмет.дійсність_створення = дійсність_створення;
    дійсність_створення.кількість_запозичень += 1;

    предмет.рідна = ні;
    предмет.назва = назва;
    предмет.параметри = параметри;
    предмет.код = код;
    предмет.тип_результату = тип_результату;
    предмет.шлях_до_теки_модулів = шлях_до_теки_модулів;
    предмет.метод_класу = пусто;

    вернути предмет;
  }

  дія створити_рідну_дію(
    М: *Машина,
    назва: *ПредметТексту,
    параметри: *ПредметПослідовності,
    тип_результату: *Предмет,
    рідна_дія: РіднаДія,
    шлях_до_теки_модулів: *ПредметДаних
  ) -> *ПредметДії {
    змінна предмет = виділити_предмет<ПредметДії>(М, М.клас_Дія);

    предмет.дійсність_створення = пусто;
    предмет.рідна = так;
    предмет.назва = назва;
    предмет.параметри = параметри;
    предмет.тип_результату = тип_результату;
    предмет.код = рідна_дія;
    предмет.шлях_до_теки_модулів = шлях_до_теки_модулів;
    предмет.метод_класу = пусто;

    вернути предмет;
  }

  дія здійснити_клас_дії(
    М: *Машина,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Неможливо створити дію вручну."), місцезнаходження);
  }

  дія предмет_дії_отримати_властивість(
    М: *Машина,
    предмет_дії: *ПредметДії,
    назва: *ПредметТексту,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо порівняти_тексти(М, назва, М.константи_назв._назва) {
      якщо предмет_дії.назва != пусто {
        вернути ПРЕДМЕТ(предмет_дії.назва);
      }

      вернути НЕДІЙСНЕ;
    }
    якщо порівняти_тексти(М, назва, М.константи_назв._параметри) {
      якщо предмет_дії.параметри != пусто {
        вернути ПРЕДМЕТ(предмет_дії.параметри);
      }

      вернути НЕДІЙСНЕ;
    }
    якщо порівняти_тексти(М, назва, М.константи_назв._тип_результату) {
      якщо предмет_дії.тип_результату != пусто {
        вернути ПРЕДМЕТ(предмет_дії.тип_результату);
      }

      вернути НЕДІЙСНЕ;
    }
    якщо порівняти_тексти(М, назва, М.константи_назв._код) {
      якщо не предмет_дії.рідна {
        вернути ПРЕДМЕТ(предмет_дії.код як *ПредметКоду);
      }

      вернути НЕДІЙСНЕ;
    }

    змінна предмет_методу = знайти_метод_в_класі(
      М,
      М.клас_Дія,
      назва
    );

    якщо предмет_методу == пусто {
      вернути НЕДІЙСНЕ;
    }

    вернути ПРЕДМЕТ(предмет_методу);
  }
}