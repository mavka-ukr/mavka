взяти визначення мавка;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Клас__чародія_текст(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію даних \"чародія_текст\"."));
    }

    змінна предмет_даних = діяльність.здійснювач.дані як *Предмет як *ПредметДаних;

    якщо предмет_даних.клас != М.клас_Клас {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію даних \"чародія_текст\"."));
    }

    вернути ПРЕДМЕТ(створити_текст(
      М,
      "<Клас>"
    ));
  }

  дія записати_метод_класу_Клас__чародія_текст(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_текст,
      М.пуста_послідовність,
      пусто,
      рідна_дія_методу_структури_Клас__чародія_текст,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Клас,
      М.константи_назв._чародія_текст,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі методу \"чародія_текст\" для класу \"Клас\".");
    }
  }
}