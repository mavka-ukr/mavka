взяти означення мавка/машина;

внутрішня дія копіювати_памʼять<Т>(
  куди: адреса<Т>,
  звідки: адреса<Т>,
  кількість: природне
) {
  змінна п: природне = 0;

  поки п < кількість {
    куди[п] = звідки[п];

    п += 1;
  }
}

внутрішня дія заповнити_памʼять<Т>(
  куди: адреса<Т>,
  значення: Т,
  кількість: природне
) {
  змінна п: природне = 0;

  поки п < кількість {
    куди[п] = значення;

    п += 1;
  }
}

