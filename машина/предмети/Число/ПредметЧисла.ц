взяти визначення мавка/машина;

внутрішня дія копіювати_памʼять<Т>(
  куди: *Т,
  звідки: *Т,
  кількість: природне
) {
  змінна п: природне = 0;

  поки п < кількість {
    куди[п] = звідки[п];

    п += 1;
  }
}

внутрішня дія заповнити_памʼять<Т>(
  куди: *Т,
  значення: Т,
  кількість: природне
) {
  змінна п: природне = 0;

  поки п < кількість {
    куди[п] = значення;

    п += 1;
  }
}

простір мавка {
  дія записати_метод_класу_Число__чародія_число(М: *Машина);
  дія записати_метод_класу_Число__чародія_текст(М: *Машина);

  дія заповнити_клас_Число(
    М: *Машина
  ) {
    М.клас_Число.вбудований = так;
    М.клас_Число.заборонити_наслідування = так;

    записати_метод_класу_Число__чародія_число(М);
    записати_метод_класу_Число__чародія_текст(М);
  }

  дія здійснити_клас_числа(
    М: *Машина,
    задіяні: Задіяні,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    змінна задіяне_значення: Значення = НЕДІЙСНЕ;

    знайти_задіяне(М, задіяні, 0, М.константи_назв._значення, задіяне_значення::адреса);

    якщо задіяне_значення.вид == ЗНедійсне {
      вернути ЧИСЛО(0.0);
    }

    якщо задіяне_значення.вид == ЗДійсне {
      вернути ЧИСЛО(1.0);
    }

    якщо задіяне_значення.вид == ЗЧисло {
      вернути задіяне_значення;
    }

    вернути здійснити_властивість(
      М,
      задіяне_значення,
      М.константи_назв._чародія_число,
      Задіяні { 0, пусто, 0, пусто },
      Місцезнаходження { пусто, 0 }
    );
  }

  дія предмет_числа_додати(
    М: *Машина,
    значення: р64,
    право: Значення,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
    якщо право.вид == ЗЧисло {
      вернути ЧИСЛО(значення + право.дані як р64);
    }

    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Додати до числа можна лише число."), місцезнаходження);
  }

  дія предмет_числа_відняти(
