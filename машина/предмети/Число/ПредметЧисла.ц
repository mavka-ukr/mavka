    }

    вернути НЕДІЙСНЕ;
  }

  дія предмет_числа_двійкове_не(
    М: *Машина,
    значення: р64,
    місцезнаходження: Місцезнаходження
  ) -> ЗначенняАбоСтанПадіння {
