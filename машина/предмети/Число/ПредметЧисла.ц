    якщо право.вид == ЗЧисло {
      вернути ЧИСЛО(значення - право.дані як р64);
    }

    вернути МІСЦЕПАДІННЯ(М, створити_текст(М, "Відняти від числа можна лише число."), місцезнаходження);
  }

