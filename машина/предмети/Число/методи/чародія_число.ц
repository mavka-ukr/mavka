взяти визначення мавка/машина;

простір мавка {
  внутрішня дія рідна_дія_методу_структури_Число__чародія_число(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗЧисло {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію числа \"чародія_число\"."));
    }

    вернути діяльність.здійснювач;
  }

  дія записати_метод_класу_Число__чародія_число(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._чародія_число,
      М.пуста_послідовність,
      пусто,
      рідна_дія_методу_структури_Число__чародія_число,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_Число,
      М.константи_назв._чародія_число,
      предмет_дії
    );

    якщо М.стан_падіння {
      ЗАПАНІКУВАТИ(М, "Помилка при записі дії \"чародія_число\" для структури \"Число\".");
    }
  }
}