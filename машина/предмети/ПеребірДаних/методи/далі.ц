взяти визначення мавка;

простір мавка {
  внутрішня дія рідна_дія_метода_структури_ПеребірДаних__далі(
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння {
    якщо діяльність.здійснювач.вид != ЗПредмет {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію перебору даних \"далі\"."));
    }

    змінна предмет_перебору_даних = діяльність.здійснювач.дані як *Предмет як *ПредметПереборуДаних;

    якщо предмет_перебору_даних.клас != М.клас_ПеребірДаних {
      вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію перебору даних \"далі\"."));
    }

    якщо предмет_перебору_даних.почато {
      предмет_перебору_даних.позиція += 1;
    } інакше {
      предмет_перебору_даних.позиція = 0;
      предмет_перебору_даних.почато = так;
    }

    якщо предмет_перебору_даних.позиція < предмет_перебору_даних.предмет_даних.розмір {
      предмет_перебору_даних.поточне_значення = р64(предмет_перебору_даних.предмет_даних.дані[предмет_перебору_даних.позиція]);

      вернути ДІЙСНЕ;
    }

    вернути НЕДІЙСНЕ;
  }

  дія записати_метод_класу_ПеребірДаних__далі(
    М: *Машина
  ) {
    змінна предмет_дії = створити_рідну_дію(
      М,
      М.константи_назв._далі,
      М.пуста_послідовність,
      пусто,
      рідна_дія_метода_структури_ПеребірДаних__далі,
      пусто
    );

    записати_метод_класу(
      М,
      М.клас_ПеребірДаних,
      М.константи_назв._далі,
      предмет_дії
    );
  }
}