    стала ФКолірТекстуСиній = 3;
    стала ФКолірТекстуЖовтий = 4;

    структура КористувацькіДаніПристроюМавки {
      шлях_до_теки_модулів: *Притриманий; // ПредметДаних
      шлях_до_теки_паків: *Притриманий; // ПредметДаних
    }

    дія створити_машину() -> *Машина;
    дія розібрати_шлях_початкового_модуля(М: *Машина, шлях: *ПредметДаних, вихід_абсолютного_шляху: **ПредметДаних, вихід_теки_модулів: **ПредметДаних, вихід_теки_паків: **ПредметДаних, вихід_назви_модуля: **ПредметТексту) -> логічне;
    дія записати_шлях_до_теки_модулів_та_паків(М: *Машина, шлях_до_теки_модулів: *ПредметДаних, шлях_до_теки_паків: *ПредметДаних);
    дія взяти_файл(М: *Машина, шлях_до_файлу: *ПредметДаних, назва_модуля: *ПредметТексту, місцезнаходження: Місцезнаходження) -> ЗначенняАбоСтанПадіння;
    дія надрукувати_інформацію_падіння(М: *Машина, інформація_падіння: ІнформаціяПадіння);
    дія вивести_значення(М: *Машина, значення: Значення, розмір_відступу: природне, глибина: природне);
    дія надрукувати_значення(М: *Машина, значення: Значення, розмір_відступу: природне, глибина: природне);
    дія визначити_глобально_мавка(М: *Машина);
    дія визначити_глобальні_виводу(М: *Машина);
    дія почати_діалог(М: *Машина, шлях_до_теки_модулів: *ПредметДаних, шлях_до_файлу_стандартного_входу: *ПредметДаних);
  }
