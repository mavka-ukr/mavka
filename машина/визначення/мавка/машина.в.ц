  структура Накопичувач<Т> {
    розмір: природне;
    дані: *Т;
    вмісткість: природне;
  }

  внутрішня дія виділити_накопичувач<Т>(М: *Машина, початкова_вмісткість: природне) -> *Накопичувач<Т> {
    змінна накопичувач = виділити<Накопичувач<Т>>();

    накопичувач.розмір = 0;
    якщо початкова_вмісткість > 0 {
      накопичувач.дані = виділити<Т>(М, початкова_вмісткість);
    } інакше {
      накопичувач.дані = пусто;
    }
    накопичувач.вмісткість = початкова_вмісткість;

