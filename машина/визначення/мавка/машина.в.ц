/* Машина Мавки */

простір мавка {
  структура Місцезнаходження;
  структура Притриманий;
  структура Притримувач;
  структура КористувацькіДані;
  структура Предмет;
  структура ПредметПослідовності;
  структура Дійсність;
  структура ПредметДаних;
  структура ПредметПроміжкаЧисел;
  структура ПредметДії;
  структура ПредметКоду;
  структура ПредметМодуля;
  структура ПредметПараметра;
  структура ПредметОзнаки;
  структура ПредметПереборуПроміжкаЧисел;
  структура ПредметПереборуСписку;
  структура ПредметСловника;
  структура ПредметСписку;
  структура ПредметКласу;
  структура ПредметТексту;
  структура СкладенийПредмет;
  структура Машина;

  стала ЗНедійсне = 0;
  стала ЗДійсне = 1;
  стала ЗЧисло = 2;
  стала ЗПредмет = 3;

  структура Значення {
    дані: *Предмет | р64;
    вид: п8;
  }

  стала НЕДІЙСНЕ = Значення { дані = пусто як *Предмет, вид = ЗНедійсне };
  стала ДІЙСНЕ = Значення { дані = пусто як *Предмет, вид = ЗДійсне };

  внутрішня дія ЧИСЛО(значення: р64) -> Значення {
    вернути Значення { дані = значення, вид = ЗЧисло };
  }

  внутрішня дія ПРЕДМЕТ(предмет: адреса) -> Значення {
    вернути Значення { дані = предмет як *Предмет, вид = ЗПредмет };
  }

  внутрішня дія ЛОГЛОГ(значення: логічне) -> Значення {
    якщо значення {
      вернути ДІЙСНЕ;
    } інакше {
      вернути НЕДІЙСНЕ;
    }
  }

  синонім ЗначенняАбоСтанПадіння = Значення;
  синонім СтанПадіння = ніщо;

  стала ВПокластиНедійсне = 0; // []() -> [недійсне]
  стала ВПокластиДійсне = 1; // []() -> [дійсне]
  стала ВПокластиПредмет = 3; // []() -> [Предмет]
  стала ВПокластиЯ = 4; // []() -> [значення_я]
  стала ВПокластиКонстанту = 5; // [](позиція_константи) -> [константа]
  стала ВСтворитиПослідовність = 6; // [...](кількість_елементів) -> [значення_послідовності]
  стала ВСтворитиДію = 7; // [назва, ..., тип_результату, код](кількість_параметрів) -> [предмет_дії]
  стала ВСтворитиКлас = 8; // [назва, ...](кількість_параметрів) -> [предмет_класу]
  стала ВСтворитиМодуль = 9; // [назва, код]() -> [предмет_модуля]
  стала ВСтворитиСписок = 10; // [...](кількість_елементів) -> [предмет_списку]
  стала ВСтворитиСловник = 11; // [...](кількість_елементів) -> [предмет_словника]
  стала ВСтворитиПроміжок = 12; // [від, включно, до]() -> [предмет_проміжка]
  стала ВСтворитиПараметр = 13; // [назва, тип, значення]() -> [параметр]
  стала ВСтворитиОзнаку = 68; // [назва, тип, значення]() -> [ознака]
  стала ВСтворитиТип = 14; // [...](кількість_структур) -> [тип]
  стала ВЗаписатиМетод = 15; // [предмет_класу, назва, предмет_дії]() -> [предмет_дії]
  стала ВВизначити = 16; // [назва, значення]() -> []
  стала ВЗвернутись = 17; // [назва]() -> [предмет]
  стала ВЗдійснити = 18; // [предмет_дії, ..., ...](кількість_аргументів, кількість_іменованих_аргументів) -> [результат]
  стала ВОтриматиВластивість = 19; // [предмет, назва]() -> [предмет_властивості]
  стала ВЗмінитиВластивість = 20; // [предмет, назва, значення]() -> []
  стала ВЗдійснитиВластивість = 21; // [предмет, назва, ..., ...](кількість_аргументів, кількість_іменованих_аргументів) -> [результат]
  стала ВОтриматиЕлемент = 22; // [предмет, ключ]() -> [елемент]
  стала ВЗмінитиЕлемент = 23; // [предмет, ключ, значення]() -> []
  стала ВОтриматиПеребір = 24; // [предмет]() -> [предмет_перебору]
  стала ВДодати = 25; // [а, б]() -> [результат]
  стала ВВідняти = 26; // [а, б]() -> [результат]
  стала ВПомножити = 27; // [а, б]() -> [результат]
  стала ВПоділити = 28; // [а, б]() -> [результат]
  стала ВОтриматиОстачуДілення = 29; // [а, б]() -> [результат]
  стала ВОтриматиНеповнуЧасткуДілення = 30; // [а, б]() -> [результат]
  стала ВПіднестиДоСтепеня = 31; // [а, б]() -> [результат]
  стала ВЗсунутиВліво = 32; // [а, б]() -> [результат]
  стала ВЗсунутиВправо = 33; // [а, б]() -> [результат]
  стала ВЗсунутиВправо2 = 34; // [а, б]() -> [результат]
  стала ВДвійковеІ = 35; // [а, б]() -> [результат]
  стала ВДвійковеАБО = 36; // [а, б]() -> [результат]
  стала ВДвійковеВиключнеАБО = 37; // [а, б]() -> [результат]
  стала ВМенше = 38; // [а, б]() -> [результат]
  стала ВБільше = 39; // [а, б]() -> [результат]
  стала ВНеБільше = 40; // [а, б]() -> [результат]
  стала ВНеМенше = 41; // [а, б]() -> [результат]
  стала ВРівно = 42; // [а, б]() -> [результат]
  стала ВНеРівно = 43; // [а, б]() -> [результат]
  стала ВЄ = 46; // [а, б]() -> [результат]
  стала ВНеЄ = 47; // [а, б]() -> [результат]
  стала ВДвійковеНЕ = 48; // [а]() -> [результат]
  стала ВВідʼємне = 49; // [а]() -> [результат]
  стала ВЗаперечити = 51; // [а]() -> [результат]
  стала ВПочатиСпробу = 52; // [назва](позиція_вказівки_зловити) -> []
  стала ВВпасти = 53; // [предмет_помилки]() -> []
  стала ВЗакінчитиСпробу = 54; // [](позиція_вказівки_виходу) -> []
  стала ВВзяти = 55; // [назва, ...](кількість_назв) -> [предмет_модуля]
  стала ВДати = 56; // [предмет, назва]() -> []
  стала ВПеребратиДалі = 57; // [предмет_перебору]() -> [предмет_перебору, результат_виконання]
  стала ВЗбитиТекст = 58; // [...](кількість_предметів) -> [збитий_текст]
  стала ВСтрибнути = 59; // [](позиція_вказівки) -> []
  стала ВСтрибнутиЯкщоНедійсне = 60; // [предмет](позиція_вказівки) -> []
  стала ВЗабрати = 61; // [предмет]() -> []
  стала ВВернути = 62; // [предмет]() -> []
  стала ВСтрибнутиЯкщоДійсне = 63; // [предмет](позиція_вказівки) -> [предмет]
  стала ВДублювати = 64; // [предмет]() -> [предмет, предмет]
  стала ВВизначитиНавпаки = 65; // [значення, назва]() -> []
  стала ВВизначитиШвидко = 66; // [значення](позиція_в_дійсності) -> []
  стала ВЗвернутисьШвидко = 67; // [](позиція_в_дійсності) -> [предмет]

  структура Шлях {
    розмір: природне;
    дані: *п8;
  }

  структура Місцезнаходження {
    шлях_або_код: *ПредметДаних | *ПредметКоду;
    рядок_або_позиція_вказівки: природне;
  }

  структура Притриманий {
    попередній: *Притриманий;
    наступний: *Притриманий;
    предмет: *Предмет;
  }

  структура Притримувач {
    наступний: *Притримувач;
    попередній: *Притримувач;
    перший: *Притриманий;
    останній: *Притриманий;
  }

  синонім ДіяПередЗнищеннямКористувацькихДаних = (М: *Машина, користувацькі_дані: *КористувацькіДані) -> ніщо;

  структура КористувацькіДані {
    значення: адреса;
    дія_перед_знищенням: ДіяПередЗнищеннямКористувацькихДаних;
  }

  структура НакопичувачТексту {
    розмір: природне;
    дані: *п8;
    вмісткість: природне;
  }

  структура Предмет {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
  }

  структура ПредметПослідовності {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    розмір: природне;
    елементи: *Значення;
  }

  структура Призначене;

  структура Призначене {
    наступний: *Призначене;
    назва: *ПредметТексту;
    значення: Значення;
  }

  структура Призначення {
    розмір: природне;
    дані: **Призначене;
    вмісткість: природне;
  }

  структура Дійсність {
    попередня: *Дійсність;
    наступна: *Дійсність;
    позначено: логічне;
    кількість_запозичень: природне;
    зовні: *Дійсність;
    призначення: Призначення;
  }

  структура Метод {
    назва: *ПредметТексту;
    значення: *ПредметДії;
  }

  структура Методи {
    розмір: природне;
    дані: *Метод;
  }

  стала ВидЗадіяних1 = 1; // з накопичувача діяльності
  стала ВидЗадіяних2 = 2; // виділені користувачем

  структура Задіяні {
    вид: п8;
    розмір: п32;
    дані: *Значення;
    кількість_імен: п32;
  }

  структура Діяльність;

  синонім РіднаДія = (
    М: *Машина,
    діяльність: *Діяльність
  ) -> ЗначенняАбоСтанПадіння;

  структура ЕлементСловника {
    ключ: Значення;
    значення: Значення;
  }

  структура ПредметКласу {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    вбудований: логічне;
    заборонити_наслідування: логічне;
    назва: *ПредметТексту;
    ознаки: *ПредметПослідовності;
    методи: Методи;
    властивості: Призначення;
  }

  структура ПредметДії {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    дійсність_створення: *Дійсність;
    рідна: логічне;
    назва: *ПредметТексту;
    параметри: *ПредметПослідовності;
    тип_результату: *Предмет;
    код: *ПредметКоду | РіднаДія;
    метод_класу: *ПредметКласу;
    шлях_до_теки_модулів: *ПредметДаних;
  }

  структура ПредметСписку {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    розмір: природне;
    елементи: *Значення;
  }

  структура ПредметСловника {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    розмір: природне;
    елементи: *ЕлементСловника;
  }

  структура ПредметМодуля {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    готовий: логічне;
    назва: *ПредметТексту;
    властивості: Призначення;
  }

  структура ПредметПараметра {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    назва: *ПредметТексту;
    тип: адреса;
    значення: Значення;
  }

  структура ПредметОзнаки {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    назва: *ПредметТексту;
    тип: адреса;
    значення: Значення;
  }

  структура ПредметТексту {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    значення: кд;
  }

  структура МісцезнаходженняВказівки {
    початок: п32;
    кінець: п32;
    рядок: п32;
  }

  структура МісцезнаходженняВказівок {
    розмір: природне;
    дані: *МісцезнаходженняВказівки;
  }

  структура ПредметКоду {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    константи: *ПредметПослідовності;
    вказівки: *ПредметДаних;
    шлях: *ПредметДаних;
    місцезнаходження_вказівок: МісцезнаходженняВказівок;
  }

  структура ПредметДаних {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    розмір: природне;
    дані: *п8;
  }

  структура ПредметПроміжкаЧисел {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    від: р64;
    до: р64;
    включно: логічне;
  }

  структура ПредметПереборуДаних {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_даних: *ПредметДаних;
    почато: логічне;
    позиція: природне;
    поточне_значення: р64;
  }

  структура ПредметПереборуПроміжкаЧисел {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_проміжка: *ПредметПроміжкаЧисел;
    почато: логічне;
    поточне_значення: р64;
  }

  структура ПредметПереборуПослідовності {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_послідовності: *ПредметПослідовності;
    почато: логічне;
    позиція: природне;
    поточне_значення: Значення;
  }

  структура ПредметПереборуСловника {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_словника: *ПредметСловника;
    почато: логічне;
    позиція: природне;
    поточне_значення: Значення;
  }

  структура ПредметПереборуСписку {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_списку: *ПредметСписку;
    почато: логічне;
    позиція: природне;
    поточне_значення: Значення;
  }

  структура ПредметПереборуТексту {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    предмет_тексту: *ПредметТексту;
    почато: логічне;
    позиція: природне;
    поточне_значення: р64;
  }

  структура СкладенийПредмет {
    наступний: *Предмет;
    позначено: логічне;
    клас: *ПредметКласу;
    користувацькі_дані: *КористувацькіДані;
    властивості: Призначення;
  }

  структура Налаштування {
    виділити_сиру_памʼять: (М: *Машина, розмір: природне) -> адреса;
    перевиділити_сиру_памʼять: (М: *Машина, значення: адреса, новий_розмір: природне) -> адреса;
