простір мавка {
  внутрішня дія перевірити_чи_предмети_тексту_рівні(
    М: *Машина,
    а: *ПредметТексту,
    б: *ПредметТексту
  ) -> логічне {
    якщо а == б {
      вернути так;
    }

    якщо а.значення.розмір != б.значення.розмір {
      вернути ні;
    }

    змінна п: природне = 0;
    поки п < а.значення.розмір {
      якщо а.значення.дані[п] != б.значення.дані[п] {
        вернути ні;
      }

      п += 1;
    }

    вернути так;
  }
}