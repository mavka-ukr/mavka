      // надрукувати_кд(М, "звільнення дійсного предмету параметра");
      звільнити_предмет_параметра(М, значення як *ПредметПараметра);
      вернути;
    }

    якщо значення.клас == М.клас_Число {
      ЗАПАНІКУВАТИ(М, "[Помилка Машини][звільнити_предмет]: значення.клас == М.клас_Число");
