    якщо значення.клас == М.клас_Клас {
      // надрукувати_кд(М, "звільнення дійсного предмету структури");
      звільнити_предмет_класу(М, значення як *ПредметКласу);
      вернути;
    }

    якщо значення.клас == М.клас_Модуль {
      // надрукувати_кд(М, "звільнення дійсного предмету модуля");
      звільнити_предмет_модуля(М, значення як *ПредметМодуля);
      вернути;
