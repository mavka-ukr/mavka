простір мавка {
  внутрішня дія звільнити_предмет(М: *Машина, значення: *Предмет);
  внутрішня дія звільнити_предмет_класу(М: *Машина, предмет_класу: *ПредметКласу);
  внутрішня дія звільнити_предмет_даних(М: *Машина, предмет_даних: *ПредметДаних);
  внутрішня дія звільнити_предмет_діапазону_чисел(М: *Машина, предмет_діапазону_чисел: *ПредметДіапазонуЧисел);
  внутрішня дія звільнити_предмет_дії(М: *Машина, предмет_дії: *ПредметДії);
  внутрішня дія звільнити_предмет_коду(М: *Машина, предмет_коду: *ПредметКоду);
  внутрішня дія звільнити_предмет_модуля(М: *Машина, предмет_модуля: *ПредметМодуля);
  внутрішня дія звільнити_предмет_параметра(М: *Машина, предмет_параметра: *ПредметПараметра);
