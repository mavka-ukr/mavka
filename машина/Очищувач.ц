      // надрукувати_кд(М, "звільнення предмету словника");
      звільнити_предмет_словника(М, значення як *ПредметСловника);
      вернути;
    }

    якщо значення.клас == М.клас_Дані {
      // надрукувати_кд(М, "звільнення предмету даних");
      звільнити_предмет_даних(М, значення як *ПредметДаних);
      вернути;
    }

    якщо значення.клас == М.клас_ДіапазонЧисел {
      // надрукувати_кд(М, "звільнення предмету діапазону чисел");
      звільнити_предмет_діапазону_чисел(М, значення як *ПредметДіапазонуЧисел);
      вернути;
    }

    якщо значення.клас == М.клас_ПеребірДіапазонуЧисел {
      // надрукувати_кд(М, "звільнення предмету перебору діапазону чисел");
      звільнити_предмет_перебору_діапазону_чисел(М, значення як *ПредметПереборуДіапазонуЧисел);
      вернути;
