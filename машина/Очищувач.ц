    якщо значення.клас == М.клас_ПеребірДаних {
      // надрукувати_кд(М, "звільнення предмету перебору даних");
      звільнити_предмет_перебору_даних(М, значення як *ПредметПереборуДаних);
      вернути;
    }

    якщо значення.клас == М.клас_ПеребірПослідовності {
      // надрукувати_кд(М, "звільнення предмету перебору послідовності");
      звільнити_предмет_перебору_послідовності(М, значення як *ПредметПереборуПослідовності);
      вернути;
