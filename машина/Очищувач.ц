  внутрішня дія позначити_предмет(
    М: *Машина,
    предмет: *Предмет
  ) {
    якщо предмет.позначено {
      вернути;
    }

    якщо предмет.клас == М.клас_Клас {
      позначити_предмет_класу(М, предмет як *ПредметКласу);
      вернути;
    }

    якщо предмет.клас == М.клас_Модуль {
      позначити_предмет_модуля(М, предмет як *ПредметМодуля);
      вернути;
    }

    якщо предмет.клас == М.клас_Параметр {
      позначити_предмет_параметра(М, предмет як *ПредметПараметра);
      вернути;
    }

    якщо предмет.клас == М.клас_Число {
      ЗАПАНІКУВАТИ(М, "[Помилка Машини][позначити_предмет]: предмет.клас == М.клас_Число");
      вернути;
    }

    якщо предмет.клас == М.клас_Текст {
      позначити_предмет_тексту(М, предмет як *ПредметТексту);
      вернути;
    }

    якщо предмет.клас == М.клас_Код {
      позначити_предмет_коду(М, предмет як *ПредметКоду);
      вернути;
    }

    якщо предмет.клас == М.клас_Дія {
      позначити_предмет_дії(М, предмет як *ПредметДії);
      вернути;
    }

    якщо предмет.клас == М.клас_Список {
      позначити_предмет_списку(М, предмет як *ПредметСписку);
      вернути;
    }

    якщо предмет.клас == М.клас_Словник {
      позначити_предмет_словника(М, предмет як *ПредметСловника);
      вернути;
    }

    якщо предмет.клас == М.клас_Дані {
      позначити_предмет_даних(М, предмет як *ПредметДаних);
      вернути;
    }

    якщо предмет.клас == М.клас_ДіапазонЧисел {
      позначити_предмет_діапазону_чисел(М, предмет як *ПредметДіапазонуЧисел);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірДіапазонуЧисел {
      позначити_предмет_перебору_діапазону_чисел(М, предмет як *ПредметПереборуДіапазонуЧисел);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірДаних {
      позначити_предмет_перебору_даних(М, предмет як *ПредметПереборуДаних);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірПослідовності {
      позначити_предмет_перебору_послідовності(М, предмет як *ПредметПереборуПослідовності);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірСловника {
      позначити_предмет_перебору_словника(М, предмет як *ПредметПереборуСловника);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірСписку {
      позначити_предмет_перебору_списку(М, предмет як *ПредметПереборуСписку);
      вернути;
    }

    якщо предмет.клас == М.клас_ПеребірТексту {
      позначити_предмет_перебору_тексту(М, предмет як *ПредметПереборуТексту);
      вернути;
    }

    якщо предмет.клас == М.клас_Послідовність {
      позначити_предмет_послідовності(М, предмет як *ПредметПослідовності);
      вернути;
    }

    позначити_складений_предмет(М, предмет як *СкладенийПредмет);
  }

