      // надрукувати_кд(М, (значення як *ПредметТексту).значення);
      звільнити_предмет_тексту(М, значення як *ПредметТексту);
      вернути;
    }

    якщо значення.клас == М.клас_Код {
      // надрукувати_кд(М, "звільнення предмету коду");
      звільнити_предмет_коду(М, значення як *ПредметКоду);
      вернути;
