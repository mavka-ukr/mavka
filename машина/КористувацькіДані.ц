взяти означення мавка/машина;

простір мавка {
  дія створити_користувацькі_дані(
    М: адреса<Машина>,
    значення: невідома_адреса,
    дія_перед_знищенням: ДіяПередЗнищеннямКористувацькихДаних
  ) -> адреса<КористувацькіДані> {
    змінна користувацькі_дані = виділити<КористувацькіДані>(М, 1);

    користувацькі_дані.значення = значення;
    користувацькі_дані.дія_перед_знищенням = дія_перед_знищенням;

    вернути користувацькі_дані;
  }
}