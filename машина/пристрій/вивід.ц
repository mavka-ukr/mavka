      змінна розмір_відступу = дані.розмір_відступу;
      змінна глибина = дані.глибина;

      змінна п: природне = 0;

      поки п < виведені_властивості.розмір {
        якщо перевірити_чи_предмети_тексту_рівні(М, назва, виведені_властивості.дані[п]) {
          вернути так;
        }

        п += 1;
      }

      якщо не дані.щось_виведено::вміст {
        якщо розмір_відступу > 0 {
          вивести_кд(М, "\р");
        }
      }

      дані.щось_виведено::вміст = так;

      вивести_пропуски(М, розмір_відступу * (глибина + 1));
      вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(назва), 0, 0);
      вивести_кд(М, "=");
      вивести_значення_1(М, виведені_предмети, значення, розмір_відступу, глибина + 1);
