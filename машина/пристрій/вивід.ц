      вивести_кд(М, "(");

      змінна щось_виведено = ні;
      змінна виведені_властивості = зробити_накопичувач<*ПредметТексту>(М, предмет.клас.параметри.розмір);

      якщо предмет.клас.параметри.розмір > 0 {
        якщо розмір_відступу > 0 {
          вивести_кд(М, "\р");
        }

        змінна п: природне = 0;
        поки п < предмет.клас.параметри.розмір {
          змінна параметр = предмет.клас.параметри.елементи[п];
          змінна предмет_параметра = параметр.дані як *Предмет як *ПредметПараметра;

          покласти_в_накопичувач<*ПредметТексту>(М, виведені_властивості::адреса, предмет_параметра.назва);

          змінна значення_властивості = отримати_властивість(М, ПРЕДМЕТ(предмет), предмет_параметра.назва, Місцезнаходження { пусто, 0});
          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_параметра.назва), 0, 0);
          вивести_кд(М, "=");
          вивести_значення_1(М, виведені_предмети, значення_властивості, розмір_відступу, глибина + 1);
          вивести_кд(М, ",");
          якщо розмір_відступу > 0 {
            вивести_кд(М, "\р");
          } інакше {
            вивести_кд(М, " ");
          }

          щось_виведено = так;

          п += 1;
        }
      }

      змінна дані_дпввп = ДаніДіїПереборуВиводуВластивостейПредмета {
        предмет,
        виведені_предмети,
        виведені_властивості::адреса,
        розмір_відступу,
        глибина,
        щось_виведено::адреса
      };

      перебрати_призначення(
        М,
        (предмет як *СкладенийПредмет).властивості,
        дія_перебору_виводу_властивостей_предмета,
        дані_дпввп::адреса
      );

      звільнити(М, виведені_властивості.дані);

      якщо щось_виведено {
        вивести_пропуски(М, розмір_відступу * глибина);
      }

      вивести_кд(М, ")");

      відновити_стан_виведених_предметів(виведені_предмети, свп);
    }

    // позначка: прохід по типах предметів
    внутрішня дія вивести_значення_1(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      значення: Значення,
      розмір_відступу: природне,
      глибина: природне
    ) {
      якщо значення.вид == ЗНедійсне {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        вивести_кд(М, "недійсне");

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо значення.вид == ЗДійсне {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        вивести_кд(М, "дійсне");

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо значення.вид == ЗЧисло {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        змінна значення_кд: кд;

        якщо перетворити_р64_в_кд(М, значення.дані як р64, значення_кд::адреса) {
          вивести_кд(М, значення_кд);
        }

        звільнити(М, значення_кд.дані);

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      вивести_предмет(
        М,
        виведені_предмети,
        значення.дані як *Предмет,
        розмір_відступу,
        глибина
      );
    }

    // позначка: прохід по типах предметів
    дія вивести_значення(
      М: *Машина,
      значення: Значення,
      розмір_відступу: природне,
      глибина: природне
    ) {
      змінна виведені_предмети = зробити_накопичувач<*Предмет>(М, 32);

      вивести_значення_1(
        М,
        виведені_предмети::адреса,
        значення,
        розмір_відступу,
        глибина
      );

      звільнити(М, виведені_предмети.дані);
    }

    дія надрукувати_значення(М: *Машина, значення: Значення, розмір_відступу: природне, глибина: природне) {
      вивести_значення(
        М,
        значення,
        розмір_відступу,
        глибина
      );

      вивести_кд(М, "\р");
    }
  }
