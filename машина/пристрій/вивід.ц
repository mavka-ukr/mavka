взяти визначення мавка/пристрій;

простір мавка {
  простір пристрій {
    дія надрукувати_інформацію_падіння(
      М: *Машина,
      інформація_падіння: ІнформаціяПадіння
    ) {
      пристрій_мавки_вивести_формат(ФКолірТекстуЧервоний);
      вивести_кд(М, "Помилка");
      пристрій_мавки_вивести_формат(ФОчистити);

      якщо інформація_падіння.місцезнаходження.шлях != пусто {
        вивести_кд(М, " в ");

        пристрій_мавки_вивести_шлях(інформація_падіння.місцезнаходження.шлях.розмір, інформація_падіння.місцезнаходження.шлях.дані);

        якщо інформація_падіння.місцезнаходження.рядок > 0 {
          вивести_кд(М, ":");
          вивести_п64(М, п64(інформація_падіння.місцезнаходження.рядок));
        }

        вивести_кд(М, "\р");
      }

      надрукувати_значення(М, інформація_падіння.значення, 2, 0);

      змінна п: природне = 0;

      якщо інформація_падіння.розмір_історії > 0 {
        надрукувати_кд(М, "\рІсторія здійснення:");
      }

      поки п < інформація_падіння.розмір_історії {
        змінна елемент_історії = інформація_падіння.історія[п];

        якщо елемент_історії.назва != пусто {
          вивести_кд(М, "  ");
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, елемент_історії.назва.значення);
          пристрій_мавки_вивести_формат(ФОчистити);

          якщо елемент_історії.місцезнаходження.шлях == пусто {
            вивести_кд(М, "\р");
          } інакше {
            вивести_кд(М, " в ");
            пристрій_мавки_вивести_шлях(елемент_історії.місцезнаходження.шлях.розмір, елемент_історії.місцезнаходження.шлях.дані);

            якщо елемент_історії.місцезнаходження.рядок > 0 {
              вивести_кд(М, ":");
              вивести_п64(М, п64(елемент_історії.місцезнаходження.рядок));
            }

            вивести_кд(М, "\р");
          }
        }

        п += 1;
      }
    }

    внутрішня дія вивести_пропуски(М: *Машина, кількість: природне) {
      змінна п: природне = 0;

      поки п < кількість {
        вивести_кд(М, " ");

        п += 1;
      }
    }

    внутрішня дія вивести_вбудований_предмет(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      предмет: *Предмет,
      розмір_відступу: природне,
      глибина: природне
    );
    внутрішня дія вивести_предмет(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      предмет: *Предмет,
      розмір_відступу: природне,
      глибина: природне
    );
    внутрішня дія вивести_значення_1(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      значення: Значення,
      розмір_відступу: природне,
      глибина: природне
    );

    внутрішня дія зберегти_стан_виведених_предметів(
      виведені_предмети: *Накопичувач<*Предмет>
    ) -> природне {
      вернути виведені_предмети.розмір;
    }

    внутрішня дія відновити_стан_виведених_предметів(
      виведені_предмети: *Накопичувач<*Предмет>,
      стан: природне
    ) {
      виведені_предмети.розмір = стан;
    }

    внутрішня дія покласти_виведений_предмет(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      предмет: *Предмет
    ) {
      покласти_в_накопичувач<*Предмет>(
        М,
        виведені_предмети,
        предмет
      );
    }

    внутрішня дія предмет_вже_виведено(
      виведені_предмети: *Накопичувач<*Предмет>,
      предмет: *Предмет
    ) -> логічне {
      змінна п: природне = 0;

      поки п < виведені_предмети.розмір {
        якщо виведені_предмети.дані[п] == предмет {
          вернути так;
        }

        п += 1;
      }

      вернути ні;
    }

    внутрішня дія вивести_вбудований_предмет(
      М: *Машина,
      виведені_предмети: *Накопичувач<*Предмет>,
      предмет: *Предмет,
      розмір_відступу: природне,
      глибина: природне
    ) {
      якщо предмет.клас == М.клас_Клас {
        змінна властивості = предмет як *ПредметКласу;

        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

        якщо властивості.назва == пусто {
          вивести_кд(М, "<клас>");
        } інакше {
          вивести_кд(М, "<клас ");

          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(властивості.назва), 0, 0);

          вивести_кд(М, ">");
        }

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо предмет.клас == М.клас_Модуль {
        змінна властивості_модуля = предмет як *ПредметМодуля;

        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

        якщо властивості_модуля.назва == пусто {
          вивести_кд(М, "<модуль");
        } інакше {
          вивести_кд(М, "<модуль ");

          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(властивості_модуля.назва), 0, 0);
        }

        якщо властивості_модуля.властивості.вмісткість > 0 {
          вивести_кд(М, "[");
          змінна п: природне = 0;
          змінна виведено_першу = ні;

          поки п < властивості_модуля.властивості.вмісткість {
            змінна призначене = властивості_модуля.властивості.дані[п];

            поки призначене != пусто {
              якщо виведено_першу {
                вивести_кд(М, ", ");
              }

              виведено_першу = так;

              вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(призначене.назва), 0, 0);

              призначене = призначене.наступний;
            }

            п += 1;
          }
          вивести_кд(М, "]");
        }

        вивести_кд(М, ">");

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо предмет.клас == М.клас_Текст {
        змінна властивості = предмет як *ПредметТексту;

        якщо глибина != 0 {
          пристрій_мавки_вивести_формат(ФКолірТекстуЗелений);
          вивести_кд(М, "\"");
        }

        якщо глибина == 0 {
          вивести_кд(М, властивості.значення);
        } інакше {
          змінна п: природне = 0;
          поки п < властивості.значення.розмір {
            змінна символ = властивості.значення.дані[п];

            якщо символ == КД::символи::Міжряд {
              вивести_кд(М, "\\р");
            } інакше якщо символ == КД::символи::Дволапка {
              вивести_кд(М, "\\\"");
            } інакше якщо символ == КД::символи::Обернена_похила {
              вивести_кд(М, "\\\\");
            } інакше якщо символ == КД::символи::Дія {
              вивести_кд(М, "\\д");
            } інакше {
              вивести_кд(М, кд { 1, символ::адреса як *п8 });
            }

            п += 1;
          }
        }

        якщо глибина != 0 {
          вивести_кд(М, "\"");
          пристрій_мавки_вивести_формат(ФОчистити);
        }

        вернути;
      }

      якщо предмет.клас == М.клас_Дія {
        змінна властивості = предмет як *ПредметДії;

        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

        якщо властивості.назва == пусто {
          вивести_кд(М, "<дія>");
        } інакше {
          вивести_кд(М, "<дія ");

          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(властивості.назва), 0, 0);

          вивести_кд(М, ">");
        }

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо предмет.клас == М.клас_Параметр {
        змінна предмет_параметра = предмет як *ПредметПараметра;
        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
        вивести_кд(М, "Параметр");
        пристрій_мавки_вивести_формат(ФОчистити);
        вивести_кд(М, "(\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "назва=");
        вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_параметра.назва), розмір_відступу, глибина + 1);
        вивести_кд(М, ",\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "тип=");
        якщо предмет_параметра.тип == пусто {
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
        } інакше {
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_параметра.тип), розмір_відступу, глибина + 1);
        }
        вивести_кд(М, ",\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "дія_значення=");
        якщо предмет_параметра.дія_значення == пусто {
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
        } інакше {
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_параметра.дія_значення), розмір_відступу, глибина + 1);
        }
        вивести_кд(М, "\р");

        вивести_пропуски(М, розмір_відступу * глибина);
        вивести_кд(М, ")");
        вернути;
      }

      якщо предмет.клас == М.клас_Код {
        змінна предмет_коду = предмет як *ПредметКоду;
        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
        вивести_кд(М, "Код");
        пристрій_мавки_вивести_формат(ФОчистити);
        вивести_кд(М, "(\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "константи=");
        якщо предмет_коду.константи == пусто {
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
        } інакше {
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_коду.константи), розмір_відступу, глибина + 1);
        }
        вивести_кд(М, ",\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "вказівки=");
        якщо предмет_коду.вказівки == пусто {
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
        } інакше {
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_коду.вказівки), розмір_відступу, глибина + 1);
        }
        вивести_кд(М, ",\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "шлях=");
        якщо предмет_коду.шлях == пусто {
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
        } інакше {
          вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(предмет_коду.шлях), розмір_відступу, глибина + 1);
        }
        вивести_кд(М, ",\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "місцезнаходження_вказівок=");
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
        вивести_кд(М, "недійсне");
        пристрій_мавки_вивести_формат(ФОчистити);
        вивести_кд(М, "\р");

        вивести_пропуски(М, розмір_відступу * глибина);
        вивести_кд(М, ")");
        вернути;
      }

      якщо предмет.клас == М.клас_Список {
        змінна властивості_списку = предмет як *ПредметСписку;

        якщо предмет_вже_виведено(виведені_предмети, предмет) {
          вивести_кд(М, "[...]");
          вернути;
        }

        змінна свп = зберегти_стан_виведених_предметів(виведені_предмети);
        покласти_виведений_предмет(М, виведені_предмети, предмет);

        вивести_кд(М, "[");

        якщо властивості_списку.розмір > 0 {
          якщо розмір_відступу > 0 {
            вивести_кд(М, "\р");
          }

          змінна п: природне = 0;
          поки п < властивості_списку.розмір {
            змінна елемент = властивості_списку.елементи[п];
            вивести_пропуски(М, розмір_відступу * (глибина + 1));
            вивести_значення_1(М, виведені_предмети, елемент, розмір_відступу, глибина + 1);
            вивести_кд(М, ",");
            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            } інакше {
              вивести_кд(М, " ");
            }

            п += 1;
          }

          вивести_пропуски(М, розмір_відступу * глибина);
        }

        вивести_кд(М, "]");

        відновити_стан_виведених_предметів(виведені_предмети, свп);

        вернути;
      }

      якщо предмет.клас == М.клас_Словник {
        змінна властивості_словника = предмет як *ПредметСловника;

        якщо предмет_вже_виведено(виведені_предмети, предмет) {
          вивести_кд(М, "{...}");
          вернути;
        }

        змінна свп = зберегти_стан_виведених_предметів(виведені_предмети);
        покласти_виведений_предмет(М, виведені_предмети, предмет);

        вивести_кд(М, "{");

        якщо властивості_словника.розмір > 0 {
          якщо розмір_відступу > 0 {
            вивести_кд(М, "\р");
          }

          змінна п: природне = 0;
          поки п < властивості_словника.розмір {
            змінна пара = властивості_словника.елементи[п];
            вивести_пропуски(М, розмір_відступу * (глибина + 1));
            вивести_значення_1(М, виведені_предмети, пара.ключ, розмір_відступу, глибина + 1);
            вивести_кд(М, " => ");
            вивести_значення_1(М, виведені_предмети, пара.значення, розмір_відступу, глибина + 1);
            вивести_кд(М, ",");
            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            } інакше {
              вивести_кд(М, " ");
            }

            п += 1;
          }

          вивести_пропуски(М, розмір_відступу * глибина);
        }

        вивести_кд(М, "}");

        відновити_стан_виведених_предметів(виведені_предмети, свп);

        вернути;
      }

      якщо предмет.клас == М.клас_Дані {
        змінна предмет_даних = предмет як *ПредметДаних;
        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
        вивести_кд(М, "Дані");
        пристрій_мавки_вивести_формат(ФОчистити);
        вивести_кд(М, "(\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "розмір=");
        вивести_значення_1(М, виведені_предмети, ЧИСЛО(р64(предмет_даних.розмір)), розмір_відступу, глибина + 1);
        вивести_кд(М, "\р");

        вивести_пропуски(М, розмір_відступу * глибина);
        вивести_кд(М, ")");
        вернути;
      }

      якщо предмет.клас == М.клас_ДіапазонЧисел {
        змінна предмет_діапазону_чисел = предмет як *ПредметДіапазонуЧисел;
        пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
        вивести_кд(М, "ДіапазонЧисел");
        пристрій_мавки_вивести_формат(ФОчистити);
        вивести_кд(М, "(\р");

        вивести_пропуски(М, розмір_відступу * (глибина + 1));
        вивести_кд(М, "від=");
