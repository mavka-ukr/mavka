взяти означення мавка/пристрій;

простір мавка {
  простір пристрій {
    дія надрукувати_інформацію_падіння(
      М: адреса<Машина>,
      інформація_падіння: ІнформаціяПадіння
    ) {
      пристрій_мавки_вивести_формат(ФКолірТекстуЧервоний);
      вивести_кд(М, "Помилка");
      пристрій_мавки_вивести_формат(ФОчистити);

      якщо інформація_падіння.місцезнаходження.шлях != пусто {
        вивести_кд(М, " в ");

        пристрій_мавки_вивести_шлях(інформація_падіння.місцезнаходження.шлях.розмір, інформація_падіння.місцезнаходження.шлях.дані);

        якщо інформація_падіння.місцезнаходження.рядок > 0 {
          вивести_кд(М, ":");
          вивести_п64(М, п64(інформація_падіння.місцезнаходження.рядок));
        }

        вивести_кд(М, "\р");
      }

      надрукувати_значення(М, інформація_падіння.значення, 2, 0);

      змінна п: природне = 0;

      якщо інформація_падіння.розмір_історії > 0 {
        надрукувати_кд(М, "\рІсторія здійснення:");
      }

      поки п < інформація_падіння.розмір_історії {
        змінна елемент_історії = інформація_падіння.історія[п];

        якщо елемент_історії.назва != пусто {
          вивести_кд(М, "  ");
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, елемент_історії.назва.значення);
          пристрій_мавки_вивести_формат(ФОчистити);

          якщо елемент_історії.місцезнаходження.шлях == пусто {
            вивести_кд(М, "\р");
          } інакше {
            вивести_кд(М, " в ");
            пристрій_мавки_вивести_шлях(елемент_історії.місцезнаходження.шлях.розмір, елемент_історії.місцезнаходження.шлях.дані);

            якщо елемент_історії.місцезнаходження.рядок > 0 {
              вивести_кд(М, ":");
              вивести_п64(М, п64(елемент_історії.місцезнаходження.рядок));
            }

            вивести_кд(М, "\р");
          }
        }

        п += 1;
      }
    }

    внутрішня дія вивести_пропуски(М: адреса<Машина>, кількість: природне) {
      змінна п: природне = 0;

      поки п < кількість {
        вивести_кд(М, " ");

        п += 1;
      }
    }

    // позначка: прохід по типах предметів
    дія вивести_значення(М: адреса<Машина>, значення: Значення, розмір_відступу: природне, глибина: природне) {
      якщо значення.вид == ЗНедійсне {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        вивести_кд(М, "недійсне");

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо значення.вид == ЗДійсне {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        вивести_кд(М, "дійсне");

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      якщо значення.вид == ЗЧисло {
        пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);

        змінна значення_кд: кд;

        якщо перетворити_р64_в_кд(М, значення.дані як р64, значення_кд::адреса) {
          вивести_кд(М, значення_кд);
        }

        звільнити(М, значення_кд.дані);

        пристрій_мавки_вивести_формат(ФОчистити);

        вернути;
      }

      змінна предмет = значення.дані як адреса<Предмет>;

      // потім: обробляти рекурсію
      якщо предмет.клас.вбудований {
        якщо предмет.клас == М.клас_Клас {
          змінна властивості = предмет як адреса<ПредметКласу>;

          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

          якщо властивості.назва == пусто {
            вивести_кд(М, "<клас>");
          } інакше {
            вивести_кд(М, "<клас ");

            вивести_значення(М, ПРЕДМЕТ(властивості.назва), 0, 0);

            вивести_кд(М, ">");
          }

          пристрій_мавки_вивести_формат(ФОчистити);

          вернути;
        }

        якщо предмет.клас == М.клас_Модуль {
          змінна властивості_модуля = предмет як адреса<ПредметМодуля>;

          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

          якщо властивості_модуля.назва == пусто {
            вивести_кд(М, "<модуль");
          } інакше {
            вивести_кд(М, "<модуль ");

            вивести_значення(М, ПРЕДМЕТ(властивості_модуля.назва), 0, 0);
          }

          якщо властивості_модуля.властивості.вмісткість > 0 {
            вивести_кд(М, "[");
            змінна п: природне = 0;
            змінна виведено_першу = ні;

            поки п < властивості_модуля.властивості.вмісткість {
              змінна призначене = властивості_модуля.властивості.дані[п];

              поки призначене != пусто {
                якщо виведено_першу {
                  вивести_кд(М, ", ");
                }

                виведено_першу = так;

                вивести_значення(М, ПРЕДМЕТ(призначене.назва), 0, 0);

                призначене = призначене.наступний;
              }

              п += 1;
            }
            вивести_кд(М, "]");
          }

          вивести_кд(М, ">");

          пристрій_мавки_вивести_формат(ФОчистити);

          вернути;
        }

        якщо предмет.клас == М.клас_Параметр {
          змінна предмет_параметра = предмет як адреса<ПредметПараметра>;
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, "Параметр");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "(\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "назва=");
          вивести_значення(М, ПРЕДМЕТ(предмет_параметра.назва), розмір_відступу, глибина + 1);
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "тип=");
          якщо предмет_параметра.тип == пусто {
            пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
            вивести_кд(М, "недійсне");
            пристрій_мавки_вивести_формат(ФОчистити);
          } інакше {
            вивести_значення(М, ПРЕДМЕТ(предмет_параметра.тип), розмір_відступу, глибина + 1);
          }
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "дія_значення=");
          якщо предмет_параметра.дія_значення == пусто {
            пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
            вивести_кд(М, "недійсне");
            пристрій_мавки_вивести_формат(ФОчистити);
          } інакше {
            вивести_значення(М, ПРЕДМЕТ(предмет_параметра.дія_значення), розмір_відступу, глибина + 1);
          }
          вивести_кд(М, "\р");

          вивести_пропуски(М, розмір_відступу * глибина);
          вивести_кд(М, ")");
          вернути;
        }

        якщо предмет.клас == М.клас_Текст {
          змінна властивості = предмет як адреса<ПредметТексту>;

          якщо глибина != 0 {
            пристрій_мавки_вивести_формат(ФКолірТекстуЗелений);
            вивести_кд(М, "\"");
          }

          якщо глибина == 0 {
            вивести_кд(М, властивості.значення);
          } інакше {
            змінна п: природне = 0;
            поки п < властивості.значення.розмір {
              змінна символ = властивості.значення.дані[п];

              якщо символ == КД::символи::Міжряд {
                вивести_кд(М, "\\р");
              } інакше якщо символ == КД::символи::Дволапка {
                вивести_кд(М, "\\\"");
              } інакше якщо символ == КД::символи::Обернена_похила {
                вивести_кд(М, "\\\\");
              } інакше якщо символ == КД::символи::Дія {
                вивести_кд(М, "\\д");
              } інакше {
                вивести_кд(М, кд { 1, символ::адреса як адреса<п8> });
              }

              п += 1;
            }
          }

          якщо глибина != 0 {
            вивести_кд(М, "\"");
            пристрій_мавки_вивести_формат(ФОчистити);
          }

          вернути;
        }

        якщо предмет.клас == М.клас_Код {
          змінна предмет_коду = предмет як адреса<ПредметКоду>;
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, "Код");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "(\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "константи=");
          якщо предмет_коду.константи == пусто {
            пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
            вивести_кд(М, "недійсне");
            пристрій_мавки_вивести_формат(ФОчистити);
          } інакше {
            вивести_значення(М, ПРЕДМЕТ(предмет_коду.константи), розмір_відступу, глибина + 1);
          }
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "вказівки=");
          якщо предмет_коду.вказівки == пусто {
            пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
            вивести_кд(М, "недійсне");
            пристрій_мавки_вивести_формат(ФОчистити);
          } інакше {
            вивести_значення(М, ПРЕДМЕТ(предмет_коду.вказівки), розмір_відступу, глибина + 1);
          }
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "шлях=");
          якщо предмет_коду.шлях == пусто {
            пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
            вивести_кд(М, "недійсне");
            пристрій_мавки_вивести_формат(ФОчистити);
          } інакше {
            вивести_значення(М, ПРЕДМЕТ(предмет_коду.шлях), розмір_відступу, глибина + 1);
          }
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "місцезнаходження_вказівок=");
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          вивести_кд(М, "недійсне");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "\р");

          вивести_пропуски(М, розмір_відступу * глибина);
          вивести_кд(М, ")");
          вернути;
        }

        якщо предмет.клас == М.клас_Дія {
          змінна властивості = предмет як адреса<ПредметДії>;

          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);

          якщо властивості.назва == пусто {
            вивести_кд(М, "<дія>");
          } інакше {
            вивести_кд(М, "<дія ");

            вивести_значення(М, ПРЕДМЕТ(властивості.назва), 0, 0);

            вивести_кд(М, ">");
          }

          пристрій_мавки_вивести_формат(ФОчистити);

          вернути;
        }

        якщо предмет.клас == М.клас_Список {
          змінна властивості_списку = предмет як адреса<ПредметСписку>;

          вивести_кд(М, "[");

          якщо властивості_списку.розмір > 0 {
            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            }

            змінна п: природне = 0;
            поки п < властивості_списку.розмір {
              змінна елемент = властивості_списку.елементи[п];
              вивести_пропуски(М, розмір_відступу * (глибина + 1));
              вивести_значення(М, елемент, розмір_відступу, глибина + 1);
              якщо п + 1 < властивості_списку.розмір {
                вивести_кд(М, ",");
                якщо розмір_відступу > 0 {
                  вивести_кд(М, "\р");
                } інакше {
                  вивести_кд(М, " ");
                }
              }

              п += 1;
            }

            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            }
            вивести_пропуски(М, розмір_відступу * глибина);
          }

          вивести_кд(М, "]");

          вернути;
        }

        якщо предмет.клас == М.клас_Словник {
          змінна властивості_словника = предмет як адреса<ПредметСловника>;

          вивести_кд(М, "{");
          якщо властивості_словника.розмір > 0 {
            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            }

            змінна п: природне = 0;
            поки п < властивості_словника.розмір {
              змінна пара = властивості_словника.елементи[п];
              вивести_пропуски(М, розмір_відступу * (глибина + 1));
              вивести_значення(М, пара.ключ, розмір_відступу, глибина + 1);
              вивести_кд(М, " => ");
              вивести_значення(М, пара.значення, розмір_відступу, глибина + 1);
              якщо п + 1 < властивості_словника.розмір {
                вивести_кд(М, ",");
                якщо розмір_відступу > 0 {
                  вивести_кд(М, "\р");
                } інакше {
                  вивести_кд(М, " ");
                }
              }

              п += 1;
            }

            якщо розмір_відступу > 0 {
              вивести_кд(М, "\р");
            }
            вивести_пропуски(М, розмір_відступу * глибина);
          }

          вивести_кд(М, "}");

          вернути;
        }

        якщо предмет.клас == М.клас_Дані {
          змінна предмет_даних = предмет як адреса<ПредметДаних>;
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, "Дані");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "(\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "розмір=");
          вивести_значення(М, ЧИСЛО(р64(предмет_даних.розмір)), розмір_відступу, глибина + 1);
          вивести_кд(М, "\р");

          вивести_пропуски(М, розмір_відступу * глибина);
          вивести_кд(М, ")");
          вернути;
        }

        якщо предмет.клас == М.клас_ДіапазонЧисел {
          змінна предмет_діапазону_чисел = предмет як адреса<ПредметДіапазонуЧисел>;
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, "ДіапазонЧисел");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "(\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "від=");
          вивести_значення(М, ЧИСЛО(р64(предмет_діапазону_чисел.від)), розмір_відступу, глибина + 1);
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "до=");
          вивести_значення(М, ЧИСЛО(р64(предмет_діапазону_чисел.до)), розмір_відступу, глибина + 1);
          вивести_кд(М, ",\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "включно=");
          пристрій_мавки_вивести_формат(ФКолірТекстуЖовтий);
          якщо предмет_діапазону_чисел.включно {
            вивести_кд(М, "дійсне");
          } інакше {
            вивести_кд(М, "недійсне");
          }
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "\р");

          вивести_пропуски(М, розмір_відступу * глибина);
          вивести_кд(М, ")");
          вернути;
        }

        якщо предмет.клас == М.клас_ПеребірДіапазонуЧисел {
          змінна предмет_перебору_діапазону_чисел = предмет як адреса<ПредметПереборуДіапазонуЧисел>;
          пристрій_мавки_вивести_формат(ФКолірТекстуСиній);
          вивести_кд(М, "ПеребірДіапазонуЧисел");
          пристрій_мавки_вивести_формат(ФОчистити);
          вивести_кд(М, "(\р");

          вивести_пропуски(М, розмір_відступу * (глибина + 1));
          вивести_кд(М, "діапазон=");
