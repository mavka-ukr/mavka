        п += 1;
      }
    }

    змінна дані_дпввп = ДаніДіїПереборуВиводуВластивостейПредмета {
      предмет,
      виведені_предмети,
      виведені_властивості::адреса,
      розмір_відступу,
      глибина,
      щось_виведено::адреса
    };

    перебрати_призначення(
      М,
      (предмет як *СкладенийПредмет).властивості,
      дія_перебору_виводу_властивостей_предмета,
      дані_дпввп::адреса
    );

    звільнити(М, виведені_властивості.дані);

    якщо щось_виведено {
      вивести_пропуски(М, розмір_відступу * глибина);
    }

    вивести_кд(М, ")");

    відновити_стан_виведених_предметів(виведені_предмети, свп);
  }

  // позначка: прохід по типах предметів
  внутрішня дія вивести_значення_1(
    М: *Машина,
    виведені_предмети: *Накопичувач<*Предмет>,
    значення: Значення,
    розмір_відступу: природне,
    глибина: природне
  ) {
    якщо значення.вид == ЗНедійсне {
      вивести_кольорово(М, КолірВиводуЖовтий, "недійсне");

      вернути;
    }

    якщо значення.вид == ЗДійсне {
      вивести_кольорово(М, КолірВиводуЖовтий, "дійсне");

      вернути;
    }

    якщо значення.вид == ЗЧисло {
      змінна значення_кд: кд;

      якщо перетворити_р64_в_кд(М, значення.дані як р64, значення_кд::адреса) {
        вивести_кольорово(М, КолірВиводуЖовтий, значення_кд);
      }

      звільнити(М, значення_кд.дані);

      вернути;
    }

    вивести_предмет(
      М,
      виведені_предмети,
      значення.дані як *Предмет,
      розмір_відступу,
      глибина
    );
  }

  // позначка: прохід по типах предметів
  дія вивести_значення(
    М: *Машина,
    значення: Значення,
    розмір_відступу: природне,
    глибина: природне
  ) {
    змінна виведені_предмети = зробити_накопичувач<*Предмет>(М, 32);

    вивести_значення_1(
      М,
      виведені_предмети::адреса,
      значення,
      розмір_відступу,
      глибина
    );

    звільнити(М, виведені_предмети.дані);
  }

  дія надрукувати_значення(М: *Машина, значення: Значення, розмір_відступу: природне, глибина: природне) {
    вивести_значення(
      М,
      значення,
      розмір_відступу,
      глибина
    );

    вивести_кд(М, "\р");
  }
