  внутрішня дія дія_перебору_виводу_властивостей_предмета(
    М: *Машина,
    призначення: Призначення,
    назва: *ПредметТексту,
    значення: Значення,
    аргумент: адреса
  ) -> логічне {
    змінна дані = аргумент як *ДаніДіїПереборуВиводуВластивостейПредмета;
    змінна предмет = дані.предмет;
    змінна виведені_предмети = дані.виведені_предмети;
    змінна виведені_властивості = дані.виведені_властивості;
    змінна розмір_відступу = дані.розмір_відступу;
    змінна глибина = дані.глибина;

    змінна п: природне = 0;

    поки п < виведені_властивості.розмір {
      якщо порівняти_тексти(М, назва, виведені_властивості.дані[п]) {
        вернути так;
      }

      п += 1;
    }

    якщо не дані.щось_виведено::вміст {
      якщо розмір_відступу > 0 {
        вивести_кд(М, "\р");
      }
    }

    дані.щось_виведено::вміст = так;

    вивести_пропуски(М, розмір_відступу * (глибина + 1));
    вивести_значення_1(М, виведені_предмети, ПРЕДМЕТ(назва), 0, 0);
    вивести_кд(М, "=");
    вивести_значення_1(М, виведені_предмети, значення, розмір_відступу, глибина + 1);
    вивести_кд(М, ",");
    якщо розмір_відступу > 0 {
      вивести_кд(М, "\р");
    } інакше {
      вивести_кд(М, " ");
    }

    вернути так;
  }


