  дія перевірити_чи_значення_рівні(
    М: адреса<Машина>,
    а: Значення,
    б: Значення
  ) -> логічне {
    якщо а.вид != б.вид {
      вернути ні;
    }

    якщо а.вид == ЗНедійсне {
      вернути так;
    }

    якщо а.вид == ЗДійсне {
      вернути так;
    }

    якщо а.вид == ЗЧисло {
      якщо є_невизначеність(а.дані як р64) і є_невизначеність(б.дані як р64) {
        вернути ні;
      }

      вернути (а.дані як р64) == (б.дані як р64);
    }

    якщо а.вид != ЗПредмет {
      ЗАПАНІКУВАТИ(М, "Невідомий вид значення у перевірці на рівність.");
    }

    змінна а_предмет = а.дані як адреса<Предмет>;
    змінна б_предмет = б.дані як адреса<Предмет>;

    якщо а_предмет.клас == б_предмет.клас {
      якщо а_предмет.клас == М.клас_Текст {
        вернути перевірити_чи_предмети_тексту_рівні(
          М,
          а_предмет як адреса<ПредметТексту>,
          б_предмет як адреса<ПредметТексту>
        );
      }

      вернути ні;
    }

    вернути ні;
  }

  дія перевірити_чи_предмет_є(
