взяти визначення мавка;

простір мавка {
  дія створити_дійсність(
    М: *Машина,
    зовні: *Дійсність
  ) -> *Дійсність {
    змінна дійсність = виділити_дійсність(М);

    якщо зовні != пусто {
      дійсність.зовні = зовні;
      зовні.кількість_запозичень += 1;
    }

    вернути дійсність;
  }

  дія записати_в_дійсність(
    М: *Машина,
    дійсність: *Дійсність,
    назва: *ПредметТексту,
    значення: Значення
  ) {
    призначити(
      М,
      дійсність.призначення::адреса,
      назва,
      значення
    );
  }

  дія знайти_в_дійсності(
    М: *Машина,
    дійсність: *Дійсність,
    назва: *ПредметТексту,
    вихід_значення: *Значення
  ) -> логічне {
    якщо знайти_призначене(
      М,
      дійсність.призначення,
      назва,
      вихід_значення
    ) {
      вернути так;
    }

    якщо дійсність.зовні != пусто {
      вернути знайти_в_дійсності(
        М,
        дійсність.зовні,
        назва,
        вихід_значення
      );
    }

    вернути ні;
  }
}