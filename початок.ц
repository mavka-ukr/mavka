дія перевірити_чи_ю8_починається_на(значення: ю8, початок: ю8) -> логічне {
  змінна п: природне = 0;

  поки п < початок.розмір {
    якщо п >= значення.розмір {
      вернути ні;
    }

    якщо значення.дані[п] != початок.дані[п] {
      вернути ні;
    }

    п += 1;
  }

  вернути так;
}

