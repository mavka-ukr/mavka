  структура Система {
    дані: адреса;
    виділити_сиру_памʼять: (система: *Система, розмір: природне) -> *п8;
    перевиділити_сиру_памʼять: (система: *Система, значення: *п8, новий_розмір: природне) -> *п8;
    звільнити_сиру_памʼять: (система: *Система, значення: адреса) -> ніщо;
  }

  внутрішня дія виділити<Т>(система: *Система, кількість: природне) -> *Т {
    вернути система.виділити_сиру_памʼять(система, кількість * Т.розмір) як *Т;
  }

  внутрішня дія перевиділити<Т>(система: *Система, значення: *Т, кількість: природне) -> *Т {
    вернути система.перевиділити_сиру_памʼять(система, значення як *п8, кількість * Т.розмір) як *Т;
  }

  внутрішня дія звільнити(система: *Система, значення: адреса) {
    система.звільнити_сиру_памʼять(система, значення);
  }
}

