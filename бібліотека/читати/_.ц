взяти визначення мавка/бібліотека;
взяти визначення мавка/пристрій;

простір мавка {
  простір бібліотека {
    внутрішня дія рідна_дія_читати(
      М: *Машина,
      діяльність: *Діяльність
    ) -> ЗначенняАбоСтанПадіння {
      змінна задіяне_перед = НЕДІЙСНЕ;
      змінна знайдено_задіяне_перед = ні;

      знайдено_задіяне_перед = знайти_задіяне(М, діяльність.задіяні, 0, М.константи_назв._перед, задіяне_перед::адреса);

      змінна перед = кд { 0, пусто };

      якщо знайдено_задіяне_перед {
        якщо задіяне_перед.вид == ЗПредмет {
          змінна предмет_задіяне_перед = задіяне_перед.дані як *Предмет як *ПредметТексту;

          якщо предмет_задіяне_перед.клас != М.клас_Текст {
            вернути ПАДІННЯ(М, створити_текст(М, "Неможливо здійснити дію \"читати\"."));
          }

          перед = предмет_задіяне_перед.значення;
        } інакше {
          вернути ПАДІННЯ(М, створити_текст(М, "Задіяне \"перед\" має бути текстом."));
        }
      }

      змінна значення: кд;
      змінна успіх = ні;
      змінна кінець_файлу = природне(ні);

      успіх = пристрій_мавки_читати_кд(
        перед.дані,
        перед.розмір,
        значення.дані::адреса,
        значення.розмір::адреса,
        кінець_файлу::адреса,
        природне(так)
      );

      якщо не успіх {
        вернути ПАДІННЯ(М, створити_текст(М, "Не вдалося прочитати зі стандартного вводу."));
      }

      якщо кінець_файлу {
        вернути НЕДІЙСНЕ;
      }

      вернути ПРЕДМЕТ(створити_текст_без_копіювання(
        М,
        значення.розмір,
        значення.дані
      ));
    }

    дія створити_дію__читати(М: *Машина) -> *ПредметДії {
      // потім: створити параметри

      вернути створити_рідну_дію(
        М,
        створити_текст(М, "читати"),
        М.пуста_послідовність,
        пусто,
        рідна_дія_читати,
        пусто
      );
    }
  }
}