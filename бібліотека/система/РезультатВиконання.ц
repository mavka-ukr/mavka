взяти означення мавка/бібліотека;
взяти означення мавка/пристрій;

простір мавка {
  простір бібліотека {
    дія записати_структуру__система__РезультатВиконання(
      М: адреса<Машина>,
      предмет_модуля: адреса<ПредметМодуля>
    ) {
      змінна кдбм = М.користувацькі_дані_бібліотеки.значення як адреса<КористувацькіДаніБібліотекиМавки>;

      змінна параметр_стдвив = створити_параметр(
        М,
        М.константи_назв._стдвив,
        пусто,
        пусто
      );
      змінна параметр_стдпом = створити_параметр(
        М,
        М.константи_назв._стдпом,
        пусто,
        пусто
      );
      змінна параметр_код = створити_параметр(
        М,
        М.константи_назв._код,
        пусто,
        пусто
      );

      змінна параметри = виділити<Значення>(М, 3);
      параметри[0] = МАШИННИЙ_ПРЕДМЕТ(параметр_стдвив);
      параметри[1] = МАШИННИЙ_ПРЕДМЕТ(параметр_стдпом);
      параметри[2] = МАШИННИЙ_ПРЕДМЕТ(параметр_код);

      змінна послідовність_параметрів = створити_послідовність_без_копіювання(
        М,
        3,
        параметри
      );

      кдбм.система__РезультатВиконання = створити_структуру(
        М,
        М.константи_назв._РезультатВиконання,
        послідовність_параметрів
      );

      предмет_модуля_змінити_властивість(
        М,
        предмет_модуля,
        М.константи_назв._РезультатВиконання,
        СКЛАДЕНИЙ_ПРЕДМЕТ(кдбм.система__РезультатВиконання),
        Місцезнаходження { пусто, 0 }
      );
    }
  }
}