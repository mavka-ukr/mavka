взяти визначення мавка/бібліотека;

простір мавка {
  простір бібліотека {
    дія ініціалізувати__система(
      М: *Машина,
      предмет_модуля: *ПредметМодуля
    ) {
      записати_клас__система__РезультатВиконання(М, предмет_модуля);
      записати_дію__система__видалити(М, предмет_модуля);
      записати_дію__система__дописати(М, предмет_модуля);
      записати_дію__система__записати(М, предмет_модуля);
      записати_дію__система__прочитати(М, предмет_модуля);
      записати_дію__система__створити_папку(М, предмет_модуля);
      записати_дію__система__виконати(М, предмет_модуля);
    }
  }
}