внутрішня дія пристрій_мавки_читати_кд(дані_перед: *п8, розмір_перед: природне, вихід_даних: **п8, вихід_розміру: *природне, вихід_кінець_файлу: *природне, дозволити_історію: природне) -> логічне {
  змінна розмір_перед_ю8: природне;
  змінна дані_перед_ю8: *п8;
  змінна позиція_помилки: природне;
  змінна успіх: логічне;

  успіх = пристрій_мавки_перекодувати_кд_в_ю8(
    розмір_перед,
    дані_перед,
    розмір_перед_ю8::адреса,
    дані_перед_ю8::адреса,
    позиція_помилки::адреса
  );
  якщо не успіх {
    вернути ні;
  }

  змінна прочитаний_розмір: природне;
  змінна прочитані_дані: *п8;

  успіх = пристрій_мавки_читати_ю8(
    дані_перед_ю8,
    розмір_перед_ю8,
    прочитані_дані::адреса,
    прочитаний_розмір::адреса,
    вихід_кінець_файлу,
    дозволити_історію
  );
  якщо не успіх {
    пристрій_мавки_звільнити_сиру_памʼять(дані_перед_ю8);
    вернути ні;
  }
  якщо вихід_кінець_файлу::вміст {
    вернути так;
  }

  пристрій_мавки_звільнити_сиру_памʼять(дані_перед_ю8);

  успіх = пристрій_мавки_перекодувати_ю8_в_кд(
    прочитаний_розмір,
    прочитані_дані,
    вихід_розміру,
    вихід_даних,
    позиція_помилки::адреса
  );

  пристрій_мавки_звільнити_сиру_памʼять(прочитані_дані);

  вернути успіх;
}

