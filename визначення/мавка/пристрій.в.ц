внутрішня дія пристрій_мавки_отримати_версію(вихід_розміру: *природне, вихід_даних: **п8) -> логічне {
  змінна розмір_ю8: природне;
  змінна дані_ю8: *п8;
  змінна позиція_помилки: природне;

  якщо не пристрій_мавки_отримати_версію_як_ю8(розмір_ю8::адреса, дані_ю8::адреса) {
    вернути ні;
  }

  якщо не пристрій_мавки_перекодувати_ю8_в_кд(розмір_ю8, дані_ю8, вихід_розміру, вихід_даних, позиція_помилки::адреса) {
    пристрій_мавки_звільнити_сиру_памʼять(дані_ю8);
    вернути ні;
  }

  пристрій_мавки_звільнити_сиру_памʼять(дані_ю8);
  вернути так;
}

внутрішня дія пристрій_мавки_вивести_кд(колір: природне, розмір: природне, дані: *п8) {
  змінна розмір_ю8: природне;
